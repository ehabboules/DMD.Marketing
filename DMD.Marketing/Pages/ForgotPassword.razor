@page "/forgotpassword"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout EmptyLayout
@rendermode InteractiveServer
@inject UserService UserSvc
@inject EmailService EmailSvc
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Forgot Password – DMD Inventory</PageTitle>

<style>
    .login-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        animation: slideIn 0.5s ease-out;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .login-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        text-align: center;
        color: white;
    }

    .login-body {
        padding: 2.5rem 2rem;
    }
</style>

<div class="login-page-wrapper">
    <MudPaper Class="login-card" Elevation="0" Style="width: 100%; max-width: 480px;">
        <div class="login-header">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size: 3rem; margin-bottom: 0.5rem;" />
            <MudText Typo="Typo.h5" Style="font-weight: 700;">Forgot Password?</MudText>
            <MudText Typo="Typo.body2" Style="opacity: 0.9; margin-top: 0.25rem;">
                Enter your email and we'll send a reset link
            </MudText>
        </div>

        <div class="login-body">
            @if (_sent)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    If an account with that email exists, a password reset link has been sent.
                    Please check your inbox (and spam folder).
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Back to Login
                </MudButton>
            }
            else
            {
                <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email Address"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Margin="Margin.Normal"
                                  Required="true"
                                  RequiredError="Email is required"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  AdornmentColor="Color.Primary"
                                  Disabled="@_processing"
                                  Class="mb-4" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-weight: 600;"
                               Disabled="@_processing">
                        @if (_processing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Sending…</span>
                        }
                        else
                        {
                            <span>Send Reset Link</span>
                        }
                    </MudButton>

                    <ValidationSummary />
                </EditForm>

                <MudDivider Class="my-4" />

                <MudText Typo="Typo.body2" Align="Align.Center">
                    <MudLink Href="/login" Color="Color.Primary">Back to Login</MudLink>
                </MudText>
            }
        </div>
    </MudPaper>
</div>

@code {
    private ForgotModel _model = new();
    private bool _processing;
    private bool _sent;

    private async Task HandleSubmit()
    {
        _processing = true;
        try
        {
            var (user, token) = await UserSvc.GeneratePasswordResetTokenAsync(_model.Email);

            if (user is not null && token is not null)
            {
                var resetUrl = $"{Navigation.BaseUri.TrimEnd('/')}resetpassword" +
                               $"?email={Uri.EscapeDataString(user.Email)}&token={token}";
                await EmailSvc.SendPasswordResetAsync(user.Email, user.FirstName ?? "", resetUrl);
            }

            _sent = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred. Please try again. ({ex.Message})", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private class ForgotModel
    {
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Enter a valid email address")]
        public string Email { get; set; } = "";
    }
}
