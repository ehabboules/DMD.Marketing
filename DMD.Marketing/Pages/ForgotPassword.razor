@page "/forgotpassword"
@layout AuthLayout
@attribute [ExcludeFromInteractiveRouting]
@inject NavigationManager Nav

<MudText Typo="Typo.h4">Forgot password?</MudText>
<MudText Typo="Typo.body1">Enter your email and we'll send a reset link.</MudText>

@if (_sent)
{
    <div class="al-alert-success">
        If an account exists for <strong>@Input.Email</strong>, a reset link has been sent.
        Check your inbox (and spam folder).
    </div>
    <a href="/login" class="al-btn-outline">← Back to sign in</a>
}
else
{
    <EditForm method="post" Model="Input" OnValidSubmit="HandleSubmit" FormName="ForgotForm">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="Input.Email"
                      Placeholder="Email address"
                      Variant="Variant.Outlined"
                      Margin="Margin.Normal"
                      InputType="InputType.Email"
                      Required="true"
                      RequiredError="Email is required."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Email"
                      AdornmentColor="Color.Primary"
                      For="() => Input.Email"
                      Class="mb-3" />

        <button type="submit" class="al-btn-primary">Send reset link</button>

        <div class="al-links">
            <a href="/login">← Back to sign in</a>
        </div>
    </EditForm>
}

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "ForgotForm")]
    public ForgotInput Input { get; set; } = new();

    private bool _sent;

    public class ForgotInput
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";
    }

    private async Task HandleSubmit()
    {
        var users = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.UserService>();
        var email = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.EmailService>();

        var (user, token) = await users.GeneratePasswordResetTokenAsync(Input.Email);

        if (user is not null && token is not null)
        {
            var req      = HttpContext.Request;
            var resetUrl = $"{req.Scheme}://{req.Host}/resetpassword?email={Uri.EscapeDataString(user.Email)}&token={token}";
            await email.SendPasswordResetAsync(user.Email, user.FirstName ?? "", resetUrl);
        }

        _sent = true;
    }
}
