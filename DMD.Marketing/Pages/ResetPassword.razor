@page "/resetpassword"
@layout AuthLayout
@attribute [ExcludeFromInteractiveRouting]
@inject NavigationManager Nav

<h1 class="al-title">Set new password</h1>
<p class="al-sub">Choose a strong password for your account.</p>

@if (_success)
{
    <div class="al-alert-success">Password reset successfully. You can now sign in.</div>
    <a href="/login" class="al-btn-primary">Sign in →</a>
}
else
{
    @if (_error is not null)
    {
        <div class="al-alert-error">@_error</div>
    }

    <EditForm method="post" Model="Input" OnValidSubmit="HandleReset" FormName="ResetForm">
        <DataAnnotationsValidator />

        <input type="hidden" name="Input.Email" value="@Input.Email" />
        <input type="hidden" name="Input.Token" value="@Input.Token" />

        <MudTextField @bind-Value="Input.NewPassword"
                      Label="New password"
                      Variant="Variant.Outlined"
                      Margin="Margin.Normal"
                      InputType="@_passwordType"
                      Required="true"
                      RequiredError="Password is required."
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      AdornmentColor="Color.Primary"
                      OnAdornmentClick="TogglePassword"
                      For="() => Input.NewPassword"
                      Class="mb-3" />

        <MudTextField @bind-Value="Input.ConfirmPassword"
                      Label="Confirm password"
                      Variant="Variant.Outlined"
                      Margin="Margin.Normal"
                      InputType="@_confirmType"
                      Required="true"
                      RequiredError="Please confirm your password."
                      Adornment="Adornment.End"
                      AdornmentIcon="@_confirmIcon"
                      AdornmentColor="Color.Primary"
                      OnAdornmentClick="ToggleConfirm"
                      For="() => Input.ConfirmPassword"
                      Class="mb-3" />

        <button type="submit" class="al-btn-primary">Reset password</button>
    </EditForm>
}

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "ResetForm")]
    public ResetInput Input { get; set; } = new();

    private bool    _success;
    private string? _error;

    private bool      _showPassword;
    private bool      _showConfirm;
    private InputType _passwordType => _showPassword ? InputType.Text : InputType.Password;
    private string    _passwordIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;
    private InputType _confirmType  => _showConfirm  ? InputType.Text : InputType.Password;
    private string    _confirmIcon  => _showConfirm
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private void TogglePassword() => _showPassword = !_showPassword;
    private void ToggleConfirm()  => _showConfirm  = !_showConfirm;

    protected override void OnInitialized()
    {
        if (HttpContext.Request.Method == "GET")
        {
            Input.Email = HttpContext.Request.Query["email"].FirstOrDefault() ?? "";
            Input.Token = HttpContext.Request.Query["token"].FirstOrDefault() ?? "";

            if (string.IsNullOrWhiteSpace(Input.Email) || string.IsNullOrWhiteSpace(Input.Token))
                _error = "Invalid or missing reset link. Please request a new one.";
        }
    }

    private async Task HandleReset()
    {
        var users     = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.UserService>();
        var (ok, err) = await users.ResetPasswordAsync(Input.Email, Input.Token, Input.NewPassword);

        if (!ok) { _error = err; return; }
        _success = true;
    }

    public class ResetInput
    {
        public string Email { get; set; } = "";
        public string Token { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
