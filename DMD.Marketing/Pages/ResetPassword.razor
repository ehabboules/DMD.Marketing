@page "/resetpassword"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout EmptyLayout
@rendermode InteractiveServer
@inject UserService UserSvc
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Reset Password – DMD Inventory</PageTitle>

<style>
    .login-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        animation: slideIn 0.5s ease-out;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .login-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        text-align: center;
        color: white;
    }

    .login-body {
        padding: 2.5rem 2rem;
    }
</style>

<div class="login-page-wrapper">
    <MudPaper Class="login-card" Elevation="0" Style="width: 100%; max-width: 480px;">
        <div class="login-header">
            <MudIcon Icon="@Icons.Material.Filled.LockReset" Style="font-size: 3rem; margin-bottom: 0.5rem;" />
            <MudText Typo="Typo.h5" Style="font-weight: 700;">Reset Your Password</MudText>
        </div>

        <div class="login-body">
            @if (_tokenInvalid)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    This reset link is invalid or has expired. Please request a new one.
                </MudAlert>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="@(() => Navigation.NavigateTo("/forgotpassword"))">
                    Request New Link
                </MudButton>
            }
            else if (_done)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Your password has been reset successfully. You can now log in with your new password.
                </MudAlert>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"
                           OnClick="@(() => Navigation.NavigateTo("/login"))">
                    Go to Login
                </MudButton>
            }
            else
            {
                <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
                    <DataAnnotationsValidator />

                    <MudTextField @bind-Value="_model.NewPassword"
                                  Label="New Password"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showNew ? InputType.Text : InputType.Password)"
                                  Margin="Margin.Normal"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showNew ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="@(() => _showNew = !_showNew)"
                                  HelperText="At least 8 characters with uppercase, lowercase, number and special character"
                                  Disabled="@_processing"
                                  Class="mb-3" />

                    <MudTextField @bind-Value="_model.ConfirmPassword"
                                  Label="Confirm New Password"
                                  Variant="Variant.Outlined"
                                  InputType="@(_showConfirm ? InputType.Text : InputType.Password)"
                                  Margin="Margin.Normal"
                                  Required="true"
                                  RequiredError="Please confirm your password"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@(_showConfirm ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                  OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                                  Disabled="@_processing"
                                  Class="mb-4" />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-weight: 600;"
                               Disabled="@_processing">
                        @if (_processing)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>Resetting…</span>
                        }
                        else
                        {
                            <span>Reset Password</span>
                        }
                    </MudButton>

                    <ValidationSummary />
                </EditForm>
            }
        </div>
    </MudPaper>
</div>

@code {
    [SupplyParameterFromQuery] public string? Email { get; set; }
    [SupplyParameterFromQuery] public string? Token { get; set; }

    private ResetModel _model = new();
    private bool _tokenInvalid;
    private bool _processing;
    private bool _done;
    private bool _showNew;
    private bool _showConfirm;

    protected override void OnInitialized()
    {
        if (string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(Token))
            _tokenInvalid = true;
    }

    private async Task HandleSubmit()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            Snackbar.Add("Passwords do not match.", Severity.Warning);
            return;
        }

        _processing = true;
        try
        {
            var (ok, err) = await UserSvc.ResetPasswordAsync(Email!, Token!, _model.NewPassword);
            if (ok)
            {
                _done = true;
            }
            else
            {
                Snackbar.Add(err ?? "Failed to reset password.", Severity.Error);
                _tokenInvalid = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private class ResetModel
    {
        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        public string ConfirmPassword { get; set; } = "";
    }
}
