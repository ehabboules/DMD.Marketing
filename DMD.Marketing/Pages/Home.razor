@code {
    // ── Auth state (resolved after interactive hydration) ────────────
    private bool _isAuthenticated;
    private string _userInitial = "?";
    private string _userDisplayName = "there";
    private string _userEmail = "";

    // ── User profile from DB (plan badge) ───────────────────────────
    private User? _homeUser;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            // Get auth state — this triggers ProtectedLocalStorage read
            // which is only available after interactive hydration
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                _isAuthenticated = true;

                // Extract claims for display
                var name  = user.FindFirst(ClaimTypes.Name)?.Value;
                var email = user.FindFirst(ClaimTypes.Email)?.Value;

                _userInitial     = (name ?? email ?? "?").Substring(0, 1).ToUpper();
                _userDisplayName = name?.Split(' ')[0] ?? email ?? "there";
                _userEmail       = email ?? "";

                // Load user from DB for plan badge
                var idStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (int.TryParse(idStr, out var userId))
                {
                    _homeUser = await Db.Users.FindAsync(userId);
                }
            }
        }
        catch
        {
            // ProtectedLocalStorage may throw during pre-render or if
            // the token is missing/expired — silently treat as guest
            _isAuthenticated = false;
        }

        // Re-render now that auth state + user data are resolved
        StateHasChanged();
    }

    // ── Static data ───────────────────────────────────────────────────
