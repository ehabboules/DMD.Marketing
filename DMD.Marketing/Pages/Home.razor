@* ╔══════════════════════════════════════════════════════════════╗
   ║  DMD.Marketing — Homepage                                   ║
   ║  Location: DMD.Marketing/Pages/Home.razor                   ║
   ╚══════════════════════════════════════════════════════════════╝ *@

@page "/"
@rendermode InteractiveServer
@using DMD.Marketing.Components
@using System.Security.Claims
@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext Db

<PageTitle>DMD Inventory — Smart POS &amp; Inventory for Canadian Retail</PageTitle>

<!-- ══════════════════════════════════════════════════════════════════
     § 1  HERO
═══════════════════════════════════════════════════════════════════ -->
<section class="hero">

    <!-- Mesh background -->
    <div class="hero__bg">
        <div class="hero__blob hero__blob--1"></div>
        <div class="hero__blob hero__blob--2"></div>
        <div class="hero__blob hero__blob--3"></div>
        <div class="hero__grid"></div>
    </div>

    <div class="hero__inner">

        <!-- ── Copy ── -->
        <div class="hero__copy">

            <div class="eyebrow">
                <span class="eyebrow__dot"></span>
                Now available for Canadian retailers
            </div>

            <div class="hero-illustration-wrap anim-up" style="animation-delay:.05s">
                <svg viewBox="0 0 500 400" xmlns="http://www.w3.org/2000/svg" class="hero-illustration">
                    <defs>
                        <filter id="softShadow">
                            <feGaussianBlur in="SourceAlpha" stdDeviation="4" />
                            <feOffset dx="0" dy="4" result="offsetblur" />
                            <feComponentTransfer>
                                <feFuncA type="linear" slope="0.2" />
                            </feComponentTransfer>
                            <feMerge>
                                <feMergeNode />
                                <feMergeNode in="SourceGraphic" />
                            </feMerge>
                        </filter>
                    </defs>

                    <!-- Background circles -->
                    <circle cx="380" cy="120" r="80" fill="#E3F2FD" opacity="0.6" />
                    <circle cx="420" cy="100" r="50" fill="#BBDEFB" opacity="0.4" />
                    <circle cx="100" cy="300" r="60" fill="#E3F2FD" opacity="0.5" />

                    <!-- Warehouse building -->
                    <g filter="url(#softShadow)">
                        <rect x="320" y="80" width="100" height="120" rx="4" fill="#E8EEF7" />
                        <rect x="330" y="90" width="35" height="40" rx="2" fill="#B3C9E8" />
                        <rect x="375" y="90" width="35" height="40" rx="2" fill="#B3C9E8" />
                        <rect x="340" y="150" width="50" height="45" rx="2" fill="#7A9FCC" />
                        <path d="M 320 80 L 370 50 L 420 80" fill="#C5D9F0" />
                    </g>

                    <!-- Delivery truck -->
                    <g transform="translate(340, 220)" filter="url(#softShadow)">
                        <rect x="0" y="10" width="50" height="25" rx="3" fill="#0066FF" />
                        <rect x="45" y="5" width="25" height="30" rx="2" fill="#4A90E2" />
                        <rect x="50" y="10" width="15" height="15" rx="1" fill="#B3D9FF" />
                        <circle cx="15" cy="38" r="6" fill="#1a1a1a" />
                        <circle cx="15" cy="38" r="3" fill="#4a4a4a" />
                        <circle cx="55" cy="38" r="6" fill="#1a1a1a" />
                        <circle cx="55" cy="38" r="3" fill="#4a4a4a" />
                    </g>

                    <!-- Boxes stack -->
                    <g transform="translate(80, 140)" filter="url(#softShadow)">
                        <rect x="0" y="60" width="70" height="60" rx="3" fill="#FFB74D" />
                        <rect x="5" y="65" width="60" height="50" rx="2" fill="#FFE5B4" opacity="0.3" />
                        <line x1="15" y1="80" x2="55" y2="80" stroke="#FF9800" stroke-width="2" />
                        <line x1="15" y1="90" x2="55" y2="90" stroke="#FF9800" stroke-width="2" />
                        <line x1="15" y1="100" x2="45" y2="100" stroke="#FF9800" stroke-width="2" />
                        <rect x="5" y="15" width="60" height="50" rx="3" fill="#90CAF9" />
                        <rect x="10" y="20" width="50" height="40" rx="2" fill="#E3F2FD" opacity="0.4" />
                        <path d="M 25 35 L 35 30 L 45 35 L 35 40 Z" fill="#0066FF" opacity="0.5" />
                        <rect x="50" y="0" width="50" height="45" rx="3" fill="#FF6B35" />
                        <rect x="55" y="5" width="40" height="35" rx="2" fill="#FFE5DC" opacity="0.4" />
                    </g>

                    <!-- Barcode scanner -->
                    <g transform="translate(200, 180)" filter="url(#softShadow)">
                        <rect x="0" y="20" width="30" height="50" rx="4" fill="#1a1a1a" />
                        <rect x="3" y="23" width="24" height="30" rx="2" fill="#4CAF50" />
                        <line x1="8" y1="30" x2="8" y2="45" stroke="#1a1a1a" stroke-width="2" />
                        <line x1="12" y1="30" x2="12" y2="45" stroke="#1a1a1a" stroke-width="1.5" />
                        <line x1="15" y1="30" x2="15" y2="45" stroke="#1a1a1a" stroke-width="2.5" />
                        <line x1="19" y1="30" x2="19" y2="45" stroke="#1a1a1a" stroke-width="1" />
                        <line x1="22" y1="30" x2="22" y2="45" stroke="#1a1a1a" stroke-width="2" />
                        <circle cx="15" cy="60" r="3" fill="#FF6B35" />
                        <line x1="15" y1="63" x2="15" y2="75" stroke="#4a4a4a" stroke-width="2" />
                    </g>

                    <!-- POS Terminal -->
                    <g transform="translate(160, 240)" filter="url(#softShadow)">
                        <rect x="0" y="0" width="50" height="60" rx="4" fill="#0066FF" />
                        <rect x="5" y="5" width="40" height="35" rx="2" fill="#4A90E2" />
                        <rect x="8" y="8" width="34" height="28" rx="1" fill="#E3F2FD" />
                        <text x="25" y="18" text-anchor="middle" fill="#0066FF" font-size="8" font-weight="bold">$</text>
                        <text x="25" y="28" text-anchor="middle" fill="#0066FF" font-size="10" font-weight="bold">124.50</text>
                        <circle cx="15" cy="48" r="3" fill="#B3D9FF" />
                        <circle cx="25" cy="48" r="3" fill="#B3D9FF" />
                        <circle cx="35" cy="48" r="3" fill="#B3D9FF" />
                        <circle cx="15" cy="55" r="3" fill="#B3D9FF" />
                        <circle cx="25" cy="55" r="3" fill="#4CAF50" />
                        <circle cx="35" cy="55" r="3" fill="#B3D9FF" />
                    </g>

                    <!-- Clipboard with checklist -->
                    <g transform="translate(250, 100)" filter="url(#softShadow)">
                        <rect x="0" y="0" width="60" height="80" rx="3" fill="#fff" />
                        <rect x="3" y="3" width="54" height="74" rx="2" fill="#f8f9fa" />
                        <rect x="20" y="-5" width="20" height="8" rx="3" fill="#4a4a4a" />
                        <circle cx="12" cy="20" r="4" fill="#4CAF50" />
                        <path d="M 10 20 L 12 22 L 15 18" stroke="white" stroke-width="1.5" fill="none" />
                        <line x1="20" y1="20" x2="50" y2="20" stroke="#0066FF" stroke-width="2" />
                        <circle cx="12" cy="35" r="4" fill="#4CAF50" />
                        <path d="M 10 35 L 12 37 L 15 33" stroke="white" stroke-width="1.5" fill="none" />
                        <line x1="20" y1="35" x2="50" y2="35" stroke="#0066FF" stroke-width="2" />
                        <circle cx="12" cy="50" r="4" fill="#E0E0E0" />
                        <line x1="20" y1="50" x2="50" y2="50" stroke="#ccc" stroke-width="2" />
                        <circle cx="12" cy="65" r="4" fill="#E0E0E0" />
                        <line x1="20" y1="65" x2="45" y2="65" stroke="#ccc" stroke-width="2" />
                    </g>

                    <!-- Small package -->
                    <g transform="translate(90, 260)">
                        <rect x="0" y="0" width="40" height="35" rx="2" fill="#FFC947" />
                        <rect x="3" y="3" width="34" height="29" rx="1" fill="#FFE8B4" opacity="0.4" />
                        <line x1="20" y1="0" x2="20" y2="35" stroke="#FF9800" stroke-width="2" />
                        <line x1="0" y1="17" x2="40" y2="17" stroke="#FF9800" stroke-width="2" />
                    </g>
                </svg>
            </div>

            <p class="hero__sub anim-up" style="animation-delay:.35s">
                DMD Inventory gives small and medium retail businesses a powerful,
                bilingual POS system with multi-warehouse inventory, smart reporting,
                and real-time stock tracking — all in one platform.
            </p>

            <div class="hero__ctas anim-up" style="animation-delay:.45s">
                <a href="/contact" class="btn btn--primary">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    Book a Free Demo
                </a>
                <a href="/features" class="btn btn--ghost">
                    See Features
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>

            <div class="hero__stats anim-up" style="animation-delay:.55s">
                <div class="hero__stat">
                    <div class="hero__stat-num">3</div>
                    <div class="hero__stat-lbl">Languages</div>
                </div>
                <div class="hero__stat-div"></div>
                <div class="hero__stat">
                    <div class="hero__stat-num">∞</div>
                    <div class="hero__stat-lbl">Products</div>
                </div>
                <div class="hero__stat-div"></div>
                <div class="hero__stat">
                    <div class="hero__stat-num">$29</div>
                    <div class="hero__stat-lbl">Starting/mo</div>
                </div>
            </div>
        </div>

        <!-- ── App card visual ── -->
        <div class="hero__visual anim-left" style="animation-delay:.2s">

            <!-- Main terminal card -->
            <div class="app-card">
                <div class="app-card__topbar">
                    <span class="app-card__dot app-card__dot--r"></span>
                    <span class="app-card__dot app-card__dot--y"></span>
                    <span class="app-card__dot app-card__dot--g"></span>
                    <span class="app-card__label">DMD POS Terminal</span>
                    <span class="app-card__live">● Live</span>
                </div>
                <div class="app-card__body">
                    <!-- Stats row -->
                    <div class="app-mini-stats">
                        <div class="app-mini-stat">
                            <div class="app-mini-stat__val">$4,280</div>
                            <div class="app-mini-stat__key">Today's Sales</div>
                        </div>
                        <div class="app-mini-stat">
                            <div class="app-mini-stat__val">127</div>
                            <div class="app-mini-stat__key">Transactions</div>
                        </div>
                        <div class="app-mini-stat">
                            <div class="app-mini-stat__val">98%</div>
                            <div class="app-mini-stat__key">Uptime</div>
                        </div>
                    </div>
                    <!-- Progress -->
                    <div class="app-progress">
                        <div class="app-progress__labels">
                            <span>Monthly Target</span>
                            <span class="app-progress__pct">74%</span>
                        </div>
                        <div class="app-progress__track">
                            <div class="app-progress__fill" style="width:74%"></div>
                        </div>
                    </div>
                    <!-- Cart preview -->
                    <div class="app-cart">
                        <div class="app-cart__row app-cart__row--hd">
                            <span>Item</span><span>Qty</span><span>Total</span>
                        </div>
                        <div class="app-cart__row">
                            <span>Basmati Rice 5kg</span><span>2</span><span>$29.98</span>
                        </div>
                        <div class="app-cart__row">
                            <span>Mixed Nuts 500g</span><span>3</span><span>$44.97</span>
                        </div>
                        <div class="app-cart__row app-cart__row--total">
                            <span>Total (incl. GST)</span><span></span><span>$78.28</span>
                        </div>
                    </div>
                    <!-- Language badges -->
                    <div class="app-langs">
                        <span class="lang-badge">🇨🇦 EN</span>
                        <span class="lang-badge">🇫🇷 FR</span>
                        <span class="lang-badge">🇸🇦 AR</span>
                        <span class="lang-badge lang-badge--teal">Multi-Tax Ready</span>
                    </div>
                </div>
            </div>

            <!-- Floating cards -->
            <div class="float-card float-card--a">
                <div class="float-card__icon" style="background:rgba(0,191,165,0.15);color:#4DD0C4;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                </div>
                <div>
                    <div class="float-card__val">$24,831</div>
                    <div class="float-card__lbl">Today's Revenue</div>
                </div>
                <span class="float-card__badge">+12.4%</span>
            </div>

            <div class="float-card float-card--b">
                <div class="float-card__icon" style="background:rgba(255,111,0,0.15);color:#FFB74D;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div>
                    <div class="float-card__val">3 items</div>
                    <div class="float-card__lbl">Low stock alert</div>
                </div>
            </div>

        </div>
    </div>

    <!-- Wave divider -->
    <div class="hero__wave">
        <svg viewBox="0 0 1440 72" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0,36 C480,72 960,0 1440,36 L1440,72 L0,72 Z" fill="#ffffff"/>
        </svg>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § WELCOME CARD  (authenticated users only)
     ────────────────────────────────────────────────────────────────
     FIX: Replaced <AuthorizeView> with manual auth state check.
     AuthorizeView evaluates during SSR pre-render when
     ProtectedLocalStorage is NOT available, so the user appears
     unauthenticated and the Authorized block never renders.
     By checking _isAuthenticated (set in OnAfterRenderAsync after
     ProtectedLocalStorage is accessible), we guarantee the welcome
     card appears after interactive hydration completes.
═══════════════════════════════════════════════════════════════════ -->
@if (_isAuthenticated)
{
    <section class="home-welcome">
        <div class="home-welcome__inner">

            <!-- Left: avatar + identity -->
            <div class="home-welcome__identity">
                <div class="home-welcome__avatar">
                    @_userInitial
                </div>
                <div>
                    <div class="home-welcome__name">
                        Welcome back,
                        <strong>@_userDisplayName</strong>!
                    </div>
                    <div class="home-welcome__email">
                        @_userEmail
                    </div>
                </div>
            </div>

            <!-- Right: plan badge + actions -->
            <div class="home-welcome__actions">
                @if (_homeUser is not null && _homeUser.SelectedPlan != PlanSlug.None)
                {
                    <span class="home-welcome__plan-badge">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                        @_homeUser.SelectedPlan Plan
                        @(_homeUser.BillingCycle == BillingCycle.Annual ? "· Annual" : "· Monthly")
                    </span>
                }
                <a href="/profile" class="home-welcome__btn home-welcome__btn--primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/></svg>
                    My Profile
                </a>
                <a href="/changepassword" class="home-welcome__btn home-welcome__btn--ghost">Settings</a>
            </div>

        </div>
    </section>
}

<!-- ══════════════════════════════════════════════════════════════════
     § 2  TRUST BAR
═══════════════════════════════════════════════════════════════════ -->
<section class="trust-bar">
    <div class="trust-bar__inner">
        <span class="trust-bar__label">Trusted by retailers across Canada</span>
        <div class="trust-bar__items">
            @foreach (var t in _trustItems)
            {
                <div class="trust-item">
                    <span class="trust-item__icon">@t.Icon</span>
                    <span class="trust-item__text">@t.Text</span>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § 3  FEATURES
═══════════════════════════════════════════════════════════════════ -->
<section class="section section--gray" id="features">
    <div class="section__inner">
        <div class="section__head">
            <p class="section__label">What's included</p>
            <h2 class="section__title">Everything your store needs</h2>
            <p class="section__sub">
                From POS to purchase orders, DMD Inventory covers every aspect
                of running your retail business — out of the box.
            </p>
        </div>

        <div class="features-grid">
            @foreach (var f in _features)
            {
                <FeatureCard Icon="@f.Icon"
                             Title="@f.Title"
                             Description="@f.Description"
                             ColorKey="@f.Color"
                             Href="@f.Href" />
            }
        </div>

        <div class="section__cta">
            <a href="/features" class="btn btn--navy">
                See All Features
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § 4  WHY DMD  (dark section)
═══════════════════════════════════════════════════════════════════ -->
<section class="section section--dark" id="why">
    <div class="section__inner">
        <div class="why-layout">

            <div class="why-copy">
                <p class="section__label section__label--teal">Why DMD</p>
                <h2 class="section__title section__title--white">
                    Built for Canadian<br />retail — from day one
                </h2>
                <p class="why-copy__sub">
                    DMD Inventory was designed with Canadian retailers in mind —
                    full bilingual support, provincial tax calculations,
                    Interac-ready payments, and Arabic RTL for multicultural communities.
                </p>
                <a href="/about" class="btn btn--teal-outline">
                    Our Story
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>

            <div class="why-cards">
                @foreach (var p in _whyPoints)
                {
                    <div class="why-card">
                        <div class="why-card__icon">@p.Icon</div>
                        <div class="why-card__title">@p.Title</div>
                        <div class="why-card__desc">@p.Desc</div>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § 5  VERTICALS
═══════════════════════════════════════════════════════════════════ -->
<section class="section section--gray" id="solutions">
    <div class="section__inner">
        <div class="section__head">
            <p class="section__label">Solutions</p>
            <h2 class="section__title">Made for your industry</h2>
            <p class="section__sub">DMD Inventory adapts to how your business actually runs.</p>
        </div>
        <div class="verticals-grid">
            @foreach (var v in _verticals)
            {
                <a href="@v.Href" class="vertical-card">
                    <div class="vertical-card__img" style="background:@v.Bg">
                        <span class="vertical-card__emoji">@v.Icon</span>
                    </div>
                    <div class="vertical-card__body">
                        <div class="vertical-card__title">@v.Title</div>
                        <div class="vertical-card__desc">@v.Desc</div>
                        <span class="vertical-card__link">
                            Learn more
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                        </span>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § 6  PRICING
═══════════════════════════════════════════════════════════════════ -->
<section class="section" id="pricing">
    <div class="section__inner">
        <div class="section__head">
            <p class="section__label">Simple pricing</p>
            <h2 class="section__title">Transparent, no surprises</h2>
            <p class="section__sub">Start small, scale as you grow. No hidden fees, no long-term contracts.</p>
        </div>
        <PricingSection ShowAllFeatures="false" />
        <div class="section__cta">
            <a href="/pricing" style="color:#00BFA5;font-weight:600;text-decoration:none;font-size:0.95rem;">
                Compare all plans in detail →
            </a>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     § 7  CTA BANNER
═══════════════════════════════════════════════════════════════════ -->
<section class="cta-banner">
    <div class="cta-banner__blob cta-banner__blob--1"></div>
    <div class="cta-banner__blob cta-banner__blob--2"></div>
    <div class="cta-banner__inner">
        <p class="cta-banner__eyebrow">30-minute demo, no commitment</p>
        <h2 class="cta-banner__title">Ready to transform your store?</h2>
        <p class="cta-banner__sub">
            Book a free demo and see DMD Inventory in action with your own product catalog.
        </p>
        <div class="cta-banner__actions">
            <a href="/contact" class="btn btn--navy-solid">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                Book Your Free Demo
            </a>
            <a href="/pricing" class="btn btn--teal-ghost">
                View Pricing
            </a>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════
     GLOBAL STYLES
═══════════════════════════════════════════════════════════════════ -->
<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap');

    /* ── Variables ── */
    :root {
        --dmd-teal:       #00BFA5;
        --dmd-teal-light: #4DD0C4;
        --dmd-teal-dark:  #00897B;
        --dmd-teal-dim:   rgba(0,191,165,0.14);
        --dmd-navy:       #1A237E;
        --dmd-navy-dark:  #0D1457;
        --dmd-navy-mid:   #283593;
        --dmd-orange:     #FF6F00;
        --dmd-gray-bg:    #F5F7FA;
        --dmd-text:       #1A237E;
        --dmd-text-muted: #607D8B;
        --dmd-white:      #FFFFFF;
        --dmd-gray-mid:   #E2E8F0;
    }

    * { box-sizing: border-box; }

    /* ── Shared section shell ── */
    .section {
        padding: 96px 24px;
        font-family: 'DM Sans', sans-serif;
    }
    .section--gray  { background: var(--dmd-gray-bg); }
    .section--dark  { background: var(--dmd-navy-dark); }
    .section__inner {
        max-width: 1200px;
        margin: 0 auto;
    }
    .section__head {
        text-align: center;
        margin-bottom: 56px;
    }
    .section__label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--dmd-teal);
        margin: 0 0 12px;
    }
    .section__label--teal { color: var(--dmd-teal-light); }
    .section__title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
        font-weight: 800;
        color: var(--dmd-navy);
        margin: 0 0 16px;
        line-height: 1.15;
    }
    .section__title--white { color: #fff; }
    .section__sub {
        font-size: 1.0rem;
        color: var(--dmd-text-muted);
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.75;
    }
    .section__cta {
        text-align: center;
        margin-top: 40px;
    }

    /* ── Shared buttons ── */
    .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 13px 26px;
        border-radius: 12px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        text-decoration: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        cursor: pointer;
        white-space: nowrap;
    }
    .btn:hover { transform: translateY(-2px); text-decoration: none; }

    .btn--primary {
        background: var(--dmd-teal);
        color: var(--dmd-navy-dark);
        box-shadow: 0 4px 20px rgba(0,191,165,0.38);
    }
    .btn--primary:hover {
        background: var(--dmd-teal-light);
        box-shadow: 0 8px 28px rgba(0,191,165,0.50);
        color: var(--dmd-navy-dark);
    }
    .btn--ghost {
        background: transparent;
        color: var(--dmd-navy);
        border: 1.5px solid rgba(26,35,126,0.25);
    }
    .btn--ghost:hover { background: rgba(26,35,126,0.06); color: var(--dmd-navy); }

    .btn--navy {
        background: var(--dmd-navy);
        color: #fff;
        box-shadow: 0 4px 16px rgba(26,35,126,0.25);
    }
    .btn--navy:hover { background: var(--dmd-navy-mid); color: #fff; }

    .btn--teal-outline {
        background: transparent;
        color: var(--dmd-teal-light);
        border: 1.5px solid rgba(0,191,165,0.40);
    }
    .btn--teal-outline:hover { background: rgba(0,191,165,0.10); color: var(--dmd-teal-light); }

    .btn--navy-solid {
        background: var(--dmd-navy-dark);
        color: #fff;
        box-shadow: 0 4px 20px rgba(13,20,87,0.35);
    }
    .btn--navy-solid:hover { background: var(--dmd-navy); color: #fff; }

    .btn--teal-ghost {
        background: transparent;
        color: var(--dmd-navy-dark);
        border: 1.5px solid rgba(13,20,87,0.25);
    }
    .btn--teal-ghost:hover { background: rgba(13,20,87,0.06); color: var(--dmd-navy-dark); }

    /* ── Entry animations ── */
    .anim-up {
        animation: animUp 0.6s ease both;
    }
    .anim-left {
        animation: animLeft 0.7s ease both;
    }
    @@keyframes animUp {
        from { opacity: 0; transform: translateY(28px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    @@keyframes animLeft {
        from { opacity: 0; transform: translateX(40px); }
        to   { opacity: 1; transform: translateX(0); }
    }

    /* ════════════════════════════════════
       § 1  HERO
    ════════════════════════════════════ */
    .hero {
        position: relative;
        min-height: 100vh;
        background: linear-gradient(160deg, #FFFFFF 0%, #EEF2FF 50%, #E8F8F5 100%);
        overflow: hidden;
        display: flex;
        flex-direction: column;
        font-family: 'DM Sans', sans-serif;
    }

    .hero__bg { position: absolute; inset: 0; pointer-events: none; z-index: 0; }

    .hero__blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(90px);
        opacity: 0.18;
    }
    .hero__blob--1 {
        width: 640px; height: 640px;
        background: radial-gradient(circle, var(--dmd-teal) 0%, transparent 70%);
        top: -220px; right: -80px;
        animation: blobA 13s ease-in-out infinite alternate;
    }
    .hero__blob--2 {
        width: 520px; height: 520px;
        background: radial-gradient(circle, var(--dmd-navy) 0%, transparent 70%);
        bottom: -180px; left: -80px;
        animation: blobB 16s ease-in-out infinite alternate;
    }
    .hero__blob--3 {
        width: 280px; height: 280px;
        background: radial-gradient(circle, var(--dmd-teal) 0%, transparent 70%);
        top: 45%; left: 35%;
        opacity: 0.10;
        animation: blobA 20s ease-in-out infinite alternate-reverse;
    }
    .hero__grid {
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(26,35,126,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(26,35,126,0.04) 1px, transparent 1px);
        background-size: 48px 48px;
    }
    @@keyframes blobA { from { transform: translate(0,0) scale(1); } to { transform: translate(40px,-30px) scale(1.08); } }
    @@keyframes blobB { from { transform: translate(0,0) scale(1); } to { transform: translate(-30px,40px) scale(1.06); } }

    .hero__inner {
        position: relative; z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 100px 48px 72px;
        flex: 1;
        width: 100%;
    }

    /* Eyebrow */
    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(0,191,165,0.12);
        border: 1px solid rgba(0,191,165,0.35);
        border-radius: 100px;
        padding: 6px 16px;
        font-size: 0.775rem;
        font-weight: 600;
        color: var(--dmd-teal-dark);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 24px;
        animation: animUp 0.55s ease both;
    }
    .eyebrow__dot {
        width: 7px; height: 7px;
        border-radius: 50%;
        background: var(--dmd-teal);
        box-shadow: 0 0 8px var(--dmd-teal);
        animation: pulseDot 2s ease-in-out infinite;
    }
    @@keyframes pulseDot {
        0%,100% { opacity:1; transform:scale(1); }
        50%      { opacity:0.4; transform:scale(0.8); }
    }

    /* Illustration */
    .hero-illustration-wrap {
        margin-bottom: 24px;
    }
    .hero-illustration {
        width: 100%;
        max-width: 480px;
        height: auto;
        display: block;
    }

    /* H1 */
    .hero__h1 {
        display: flex;
        flex-direction: column;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: clamp(2.4rem, 4.2vw, 3.8rem);
        line-height: 1.08;
        color: var(--dmd-navy);
        margin: 0 0 24px;
        letter-spacing: -0.02em;
    }
    .hero__h1-line { display: block; }
    .hero__accent {
        font-style: normal;
        background: linear-gradient(90deg, var(--dmd-teal), var(--dmd-teal-light));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero__sub {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--dmd-text-muted);
        max-width: 500px;
        margin: 0 0 32px;
    }

    .hero__ctas {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-bottom: 40px;
    }

    /* Stats */
    .hero__stats {
        display: flex;
        align-items: center;
        gap: 24px;
    }
    .hero__stat-num {
        font-family: 'Syne', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--dmd-navy);
        line-height: 1;
    }
    .hero__stat-lbl {
        font-size: 0.75rem;
        color: var(--dmd-text-muted);
        margin-top: 3px;
        font-weight: 500;
    }
    .hero__stat-div {
        width: 1px;
        height: 36px;
        background: rgba(26,35,126,0.15);
    }

    /* App card */
    .hero__visual {
        position: relative;
        height: 460px;
    }

    .app-card {
        position: absolute;
        top: 0; left: 0; right: 0;
        max-width: 430px;
        margin: 0 auto;
        background: #1C2340;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 32px 80px rgba(0,0,0,0.45), 0 0 0 1px rgba(255,255,255,0.06);
    }
    .app-card__topbar {
        display: flex;
        align-items: center;
        gap: 6px;
        background: #141830;
        padding: 10px 16px;
    }
    .app-card__dot { width: 10px; height: 10px; border-radius: 50%; }
    .app-card__dot--r { background: #FF5F56; }
    .app-card__dot--y { background: #FFBD2E; }
    .app-card__dot--g { background: #27C93F; }
    .app-card__label {
        margin-left: 8px;
        font-size: 0.7rem; font-weight: 600;
        color: rgba(255,255,255,0.35);
        letter-spacing: 0.06em; text-transform: uppercase;
        flex: 1;
    }
    .app-card__live {
        font-size: 0.68rem; font-weight: 700;
        color: #27C93F;
        letter-spacing: 0.04em;
    }
    .app-card__body { padding: 16px; display: flex; flex-direction: column; gap: 14px; }

    .app-mini-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
    .app-mini-stat {
        background: rgba(255,255,255,0.04);
        border-radius: 10px;
        padding: 10px;
        text-align: center;
    }
    .app-mini-stat__val {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem; font-weight: 700;
        color: #fff; line-height: 1.2;
    }
    .app-mini-stat__key {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.40);
        margin-top: 2px;
    }

    .app-progress__labels {
        display: flex; justify-content: space-between;
        font-size: 0.75rem;
        color: rgba(255,255,255,0.45);
        margin-bottom: 6px;
    }
    .app-progress__pct { color: var(--dmd-teal); font-weight: 600; }
    .app-progress__track {
        background: rgba(255,255,255,0.08);
        border-radius: 100px; height: 5px;
    }
    .app-progress__fill {
        background: linear-gradient(90deg, var(--dmd-teal), var(--dmd-teal-light));
        border-radius: 100px; height: 100%;
        transition: width 0.8s ease;
    }

    .app-cart__row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 12px;
        font-size: 0.76rem;
        color: rgba(255,255,255,0.68);
        padding: 5px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .app-cart__row--hd {
        font-size: 0.65rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.06em;
        color: rgba(255,255,255,0.30);
        border-bottom: 1px solid rgba(255,255,255,0.10);
    }
    .app-cart__row--total {
        font-weight: 700; font-size: 0.88rem;
        color: var(--dmd-teal-light);
        border-bottom: none; padding-top: 8px;
    }

    .app-langs { display: flex; gap: 6px; flex-wrap: wrap; }
    .lang-badge {
        font-size: 0.72rem; font-weight: 600;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.12);
        color: rgba(255,255,255,0.70);
        padding: 4px 10px; border-radius: 100px;
    }
    .lang-badge--teal {
        background: rgba(0,191,165,0.15);
        border-color: rgba(0,191,165,0.30);
        color: var(--dmd-teal-light);
    }

    /* Floating cards */
    .float-card {
        position: absolute;
        background: #ffffff;
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(26,35,126,0.09);
        border-radius: 14px;
        padding: 11px 15px;
        display: flex; align-items: center; gap: 11px;
        min-width: 175px;
        box-shadow: 0 8px 32px rgba(26,35,126,0.12);
    }
    .float-card--a { bottom: 30px; right: -16px; animation: floatA 5s ease-in-out infinite; }
    .float-card--b { top: 20px;   right: -24px; animation: floatB 6.5s ease-in-out infinite; }
    @@keyframes floatA { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @@keyframes floatB { 0%,100%{transform:translateY(0)} 50%{transform:translateY(8px)} }
    .float-card__icon {
        width: 32px; height: 32px;
        border-radius: 9px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .float-card__val {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem; font-weight: 700;
        color: var(--dmd-navy); line-height: 1.2;
    }
    .float-card__lbl { font-size: 0.68rem; color: var(--dmd-text-muted); margin-top: 1px; }
    .float-card__badge {
        margin-left: auto;
        font-size: 0.68rem; font-weight: 700;
        padding: 3px 7px; border-radius: 6px;
        background: rgba(0,137,123,0.12); color: var(--dmd-teal-dark);
    }

    /* Wave */
    .hero__wave { position: relative; z-index: 1; line-height: 0; margin-top: auto; }
    .hero__wave svg { display: block; width: 100%; height: 56px; }

    /* ════════════════════════════════════
       § 2  TRUST BAR
    ════════════════════════════════════ */
    .trust-bar {
        background: #ffffff;
        border-bottom: 1px solid var(--dmd-gray-mid);
        padding: 20px 24px;
    }
    .trust-bar__inner {
        max-width: 1200px; margin: 0 auto;
        display: flex; align-items: center;
        gap: 32px; flex-wrap: wrap;
    }
    .trust-bar__label {
        font-size: 0.775rem; font-weight: 600;
        color: var(--dmd-text-muted);
        text-transform: uppercase; letter-spacing: 0.07em;
        white-space: nowrap;
    }
    .trust-bar__items { display: flex; gap: 28px; flex-wrap: wrap; }
    .trust-item { display: flex; align-items: center; gap: 8px; }
    .trust-item__icon { font-size: 1.1rem; }
    .trust-item__text { font-size: 0.82rem; font-weight: 500; color: var(--dmd-text-muted); }

    /* ════════════════════════════════════
       § 3  FEATURES GRID
    ════════════════════════════════════ */
    .features-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    @@media (max-width: 960px) { .features-grid { grid-template-columns: repeat(2,1fr); } }
    @@media (max-width: 600px) { .features-grid { grid-template-columns: 1fr; } }

    /* ════════════════════════════════════
       § 4  WHY DMD
    ════════════════════════════════════ */
    .why-layout {
        display: grid;
        grid-template-columns: 1fr 1.4fr;
        gap: 64px;
        align-items: center;
    }
    @@media (max-width: 960px) { .why-layout { grid-template-columns: 1fr; } }

    .why-copy__sub {
        font-size: 1rem; line-height: 1.75;
        color: rgba(255,255,255,0.55);
        margin: 20px 0 28px;
    }

    .why-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .why-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(0,191,165,0.18);
        border-radius: 16px;
        padding: 24px 20px;
        transition: background 0.2s ease, border-color 0.2s ease;
    }
    .why-card:hover {
        background: rgba(255,255,255,0.07);
        border-color: rgba(0,191,165,0.35);
    }
    .why-card__icon { font-size: 1.75rem; margin-bottom: 10px; }
    .why-card__title {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem; font-weight: 700;
        color: #fff; margin-bottom: 6px;
    }
    .why-card__desc { font-size: 0.83rem; color: rgba(255,255,255,0.48); line-height: 1.6; }

    /* ════════════════════════════════════
       § 5  VERTICALS
    ════════════════════════════════════ */
    .verticals-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
    @@media (max-width: 960px) { .verticals-grid { grid-template-columns: 1fr; } }

    .vertical-card {
        background: #fff;
        border: 1.5px solid rgba(26,35,126,0.08);
        border-radius: 18px;
        overflow: hidden;
        text-decoration: none;
        display: flex; flex-direction: column;
        transition: transform 0.22s ease, box-shadow 0.22s ease;
    }
    .vertical-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 56px rgba(26,35,126,0.10);
        text-decoration: none;
    }
    .vertical-card__img {
        height: 140px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 0;
    }
    .vertical-card__emoji { font-size: 3.5rem; filter: drop-shadow(0 4px 12px rgba(0,0,0,0.15)); }
    .vertical-card__body { padding: 24px 22px; flex: 1; display: flex; flex-direction: column; gap: 8px; }
    .vertical-card__title {
        font-family: 'Syne', sans-serif;
        font-size: 1.05rem; font-weight: 700;
        color: var(--dmd-navy);
    }
    .vertical-card__desc { font-size: 0.855rem; color: var(--dmd-text-muted); line-height: 1.65; flex: 1; }
    .vertical-card__link {
        display: inline-flex; align-items: center; gap: 4px;
        font-size: 0.825rem; font-weight: 600;
        color: var(--dmd-teal); margin-top: 8px;
        transition: gap 0.18s ease;
    }
    .vertical-card:hover .vertical-card__link { gap: 8px; }

    /* ════════════════════════════════════
       § 7  CTA BANNER
    ════════════════════════════════════ */
    .cta-banner {
        position: relative;
        background: linear-gradient(135deg, var(--dmd-teal-dark) 0%, var(--dmd-teal) 100%);
        padding: 88px 24px;
        overflow: hidden;
        text-align: center;
    }
    .cta-banner__blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(60px);
        opacity: 0.20;
        pointer-events: none;
    }
    .cta-banner__blob--1 { width: 400px; height: 400px; background: #fff; top: -150px; right: -80px; }
    .cta-banner__blob--2 { width: 300px; height: 300px; background: var(--dmd-navy); bottom: -120px; left: -60px; }
    .cta-banner__inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
    .cta-banner__eyebrow {
        font-size: 0.72rem; font-weight: 700;
        letter-spacing: 0.10em; text-transform: uppercase;
        color: rgba(13,20,87,0.65);
        margin-bottom: 12px;
    }
    .cta-banner__title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(1.8rem, 3.5vw, 2.8rem);
        font-weight: 800;
        color: var(--dmd-navy-dark);
        margin: 0 0 14px;
        line-height: 1.15;
    }
    .cta-banner__sub {
        font-size: 1rem; line-height: 1.7;
        color: rgba(13,20,87,0.65);
        margin: 0 0 36px;
    }
    .cta-banner__actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }

    /* ════════════════════════════════════
       RESPONSIVE
    ════════════════════════════════════ */
    @@media (max-width: 960px) {
        .hero__inner { grid-template-columns: 1fr; padding: 80px 24px 40px; }
        .hero__visual { height: 360px; }
        .app-card { max-width: 100%; }
        .float-card--b { display: none; }
    }
    @@media (max-width: 600px) {
        .hero__h1 { font-size: 2.2rem; }
        .hero__ctas { flex-direction: column; }
        .hero__visual { height: 280px; }
        .float-card { display: none; }
        .why-cards { grid-template-columns: 1fr; }
    }

    /* ════════════════════════════════════
       HOME WELCOME CARD
    ════════════════════════════════════ */
    .home-welcome {
        background: linear-gradient(135deg, #f0fbf8 0%, #e8eaf6 100%);
        border-bottom: 1px solid rgba(0,191,165,0.2);
    }

    .home-welcome__inner {
        max-width: 1100px;
        margin: 0 auto;
        padding: 20px 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }

    .home-welcome__identity {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .home-welcome__avatar {
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00BFA5, #1A237E);
        color: #fff;
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,191,165,0.35);
    }

    .home-welcome__name {
        font-family: 'DM Sans', sans-serif;
