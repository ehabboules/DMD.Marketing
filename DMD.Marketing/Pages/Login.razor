@page "/login"
@layout AuthLayout
@attribute [ExcludeFromInteractiveRouting]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject NavigationManager Nav

<MudText Typo="Typo.h4">Welcome back</MudText>
<MudText Typo="Typo.body1">Sign in to manage your DMD Inventory account.</MudText>

@if (_error is not null)
{
    <div class="al-alert-error">@_error</div>
}

<EditForm method="post" Model="Input" OnValidSubmit="HandleLogin" FormName="LoginForm">
    <DataAnnotationsValidator />

    <MudTextField @bind-Value="Input.Email"
                  Placeholder="Email address"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="InputType.Email"
                  Required="true"
                  RequiredError="Email is required."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Email"
                  AdornmentColor="Color.Primary"
                  For="() => Input.Email"
                  Class="mb-3" />

    <MudTextField @bind-Value="Input.Password"
                  Label="Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_passwordType"
                  Required="true"
                  Color="Color.Primary"
                  RequiredError="Password is required."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_passwordIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="TogglePassword"
                  For="() => Input.Password"
                  Class="mb-1" />
     

    <div class="al-forgot-row">
        <a href="/forgotpassword" class="al-link-sm">Forgot password?</a>
    </div>

    <button type="submit" class="al-btn-primary">Sign in</button>

    <div class="al-links">
        Don't have an account? <a href="/register">Create one →</a>
    </div>
</EditForm>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "LoginForm")]
    public LoginInput Input { get; set; } = new();

    private string?   _error;
    private bool      _showPassword;
    private InputType _passwordType => _showPassword ? InputType.Text : InputType.Password;
    private string    _passwordIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private void TogglePassword() => _showPassword = !_showPassword;

    public class LoginInput
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        public string Password { get; set; } = "";
    }

    private async Task HandleLogin()
    {
        var users = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.UserService>();
        var user  = await users.ValidateCredentialsAsync(Input.Email, Input.Password);

        if (user is null)   { _error = "Invalid email or password."; return; }
        if (!user.IsActive) { _error = "Account deactivated. Contact support."; return; }

        var userRoles = await users.GetUserRolesAsync(user.Id);
        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, user.Id.ToString()),
            new(ClaimTypes.Name,           user.Email),
            new(ClaimTypes.GivenName,      user.FirstName ?? ""),
            new(ClaimTypes.Surname,        user.LastName  ?? ""),
        };
        foreach (var ur in userRoles)
            claims.Add(new(ClaimTypes.Role, ur.Role.Name));

        await HttpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            new ClaimsPrincipal(new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme)),
            new AuthenticationProperties { IsPersistent = true });

        var returnUrl = HttpContext.Request.Query["returnUrl"].FirstOrDefault() ?? "/profile";
        Nav.NavigateTo(returnUrl, forceLoad: true);
    }
}
