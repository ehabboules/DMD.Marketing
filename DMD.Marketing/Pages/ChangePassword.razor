@page "/changepassword"
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@rendermode InteractiveServer
@inject UserService UserSvc
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Change Password – DMD Inventory</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="3" Class="pa-6">
        <MudStack Spacing="4">
            <MudText Typo="Typo.h4" Align="Align.Center" GutterBottom="true">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Class="mr-2" />
                Change Password
            </MudText>

            <MudDivider />

            @if (Forced)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Icon="@Icons.Material.Filled.Lock">
                    Your administrator requires you to change your password before continuing.
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true">@_errorMessage</MudAlert>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true">@_successMessage</MudAlert>
            }

            <EditForm Model="@_model" OnValidSubmit="HandleChangePassword">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudTextField @bind-Value="_model.CurrentPassword"
                                  Label="Current Password"
                                  Variant="Variant.Outlined"
                                  InputType="@_currentInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_currentIcon"
                                  OnAdornmentClick="@(() => _showCurrent = !_showCurrent)"
                                  AdornmentAriaLabel="Show/Hide Current Password"
                                  Required="true"
                                  RequiredError="Current password is required"
                                  Disabled="@_isProcessing"
                                  Immediate="true" />

                    <MudTextField Value="@_model.NewPassword"
                                  ValueChanged="@((string v) => { _model.NewPassword = v; CheckPasswordStrength(v); })"
                                  Label="New Password"
                                  Variant="Variant.Outlined"
                                  InputType="@_newInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_newIcon"
                                  OnAdornmentClick="@(() => _showNew = !_showNew)"
                                  AdornmentAriaLabel="Show/Hide New Password"
                                  Required="true"
                                  RequiredError="New password is required"
                                  Disabled="@_isProcessing"
                                  Immediate="true" />

                    <MudTextField @bind-Value="_model.ConfirmNewPassword"
                                  Label="Confirm New Password"
                                  Variant="Variant.Outlined"
                                  InputType="@_confirmInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_confirmIcon"
                                  OnAdornmentClick="@(() => _showConfirm = !_showConfirm)"
                                  AdornmentAriaLabel="Show/Hide Confirm Password"
                                  Required="true"
                                  RequiredError="Please confirm your new password"
                                  Disabled="@_isProcessing"
                                  HelperText="Must be at least 8 characters with uppercase, lowercase, number, and special character"
                                  Immediate="true" />

                    <ValidationSummary />

                    @if (!string.IsNullOrEmpty(_model.NewPassword))
                    {
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" GutterBottom="true">Password Strength</MudText>
                            <MudProgressLinear Color="@GetStrengthColor()"
                                               Value="@_passwordStrength"
                                               Size="Size.Large"
                                               Rounded="true"
                                               Class="mb-2" />
                            <MudText Typo="Typo.caption" Color="@GetStrengthColor()">@GetStrengthText()</MudText>
                            <MudStack Spacing="1" Class="mt-3">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasMinLength ? Color.Success : Color.Default)"
                                         Icon="@(_hasMinLength ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    8+ characters
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasUpper ? Color.Success : Color.Default)"
                                         Icon="@(_hasUpper ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Uppercase letter
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasLower ? Color.Success : Color.Default)"
                                         Icon="@(_hasLower ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Lowercase letter
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasNumber ? Color.Success : Color.Default)"
                                         Icon="@(_hasNumber ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Number
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasSpecial ? Color.Success : Color.Default)"
                                         Icon="@(_hasSpecial ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Special character
                                </MudChip>
                            </MudStack>
                        </MudPaper>
                    }

                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@_isProcessing"
                                   StartIcon="@Icons.Material.Filled.Save">
                            @if (_isProcessing)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Changing password…</span>
                            }
                            else
                            {
                                <span>Change Password</span>
                            }
                        </MudButton>

                        @if (!Forced)
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       FullWidth="true"
                                       OnClick="@(() => Navigation.NavigateTo("/"))"
                                       Disabled="@_isProcessing"
                                       StartIcon="@Icons.Material.Filled.Cancel">
                                Cancel
                            </MudButton>
                        }
                    </MudStack>
                </MudStack>
            </EditForm>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "forced")]
    private bool Forced { get; set; }

    private ChangeModel _model = new();
    private bool _isProcessing;
    private string? _errorMessage;
    private string? _successMessage;

    // Visibility toggles
    private bool _showCurrent, _showNew, _showConfirm;
    private InputType _currentInput => _showCurrent ? InputType.Text : InputType.Password;
    private string   _currentIcon   => _showCurrent ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private InputType _newInput     => _showNew     ? InputType.Text : InputType.Password;
    private string   _newIcon       => _showNew     ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private InputType _confirmInput => _showConfirm ? InputType.Text : InputType.Password;
    private string   _confirmIcon   => _showConfirm ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    // Password strength
    private double _passwordStrength;
    private bool _hasMinLength, _hasUpper, _hasLower, _hasNumber, _hasSpecial;

    private void CheckPasswordStrength(string pw)
    {
        _hasMinLength = pw.Length >= 8;
        _hasUpper     = pw.Any(char.IsUpper);
        _hasLower     = pw.Any(char.IsLower);
        _hasNumber    = pw.Any(char.IsDigit);
        _hasSpecial   = pw.Any(c => !char.IsLetterOrDigit(c));

        int count = (_hasMinLength ? 1 : 0) + (_hasUpper ? 1 : 0) + (_hasLower ? 1 : 0)
                  + (_hasNumber ? 1 : 0) + (_hasSpecial ? 1 : 0);
        _passwordStrength = (count / 5.0) * 100;
    }

    private Color GetStrengthColor() => _passwordStrength switch
    {
        <= 0 => Color.Default,
        < 40 => Color.Error,
        < 60 => Color.Warning,
        < 80 => Color.Info,
        _    => Color.Success
    };

    private string GetStrengthText() => _passwordStrength switch
    {
        <= 0 => "No password entered",
        < 40 => "Weak – add more requirements",
        < 60 => "Fair – almost there",
        < 80 => "Good – consider all requirements",
        _    => "Strong – all requirements met"
    };

    private async Task HandleChangePassword()
    {
        _errorMessage   = null;
        _successMessage = null;
        _isProcessing   = true;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            if (principal.Identity?.IsAuthenticated != true)
            {
                Navigation.NavigateTo("/login?returnUrl=/changepassword");
                return;
            }

            var userEmail = principal.FindFirst(ClaimTypes.Email)?.Value
                         ?? principal.FindFirst("email")?.Value;
            if (string.IsNullOrEmpty(userEmail))
            {
                _errorMessage = "Unable to determine your email address.";
                return;
            }

            if (_model.NewPassword != _model.ConfirmNewPassword)
            {
                _errorMessage = "New password and confirmation do not match.";
                return;
            }

            if (_model.CurrentPassword == _model.NewPassword)
            {
                _errorMessage = "New password must be different from the current password.";
                return;
            }

            var user = await UserSvc.FindByEmailAsync(userEmail);
            if (user is null)
            {
                Navigation.NavigateTo("/login");
                return;
            }

            var (ok, err) = await UserSvc.ChangePasswordAsync(user, _model.CurrentPassword, _model.NewPassword);

            if (ok)
            {
                _successMessage = "Password changed successfully! Redirecting…";
                Snackbar.Add("Password changed successfully!", Severity.Success);
                _model = new();
                await Task.Delay(2000);
                Navigation.NavigateTo("/");
            }
            else
            {
                _errorMessage = err ?? "Failed to change password. Please try again.";
                Snackbar.Add(_errorMessage, Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "An error occurred while changing your password. Please try again.";
            Snackbar.Add("Error: " + ex.Message, Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private class ChangeModel
    {
        [Required(ErrorMessage = "Current password is required")]
        public string CurrentPassword { get; set; } = "";

        [Required(ErrorMessage = "New password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmNewPassword { get; set; } = "";
    }
}
