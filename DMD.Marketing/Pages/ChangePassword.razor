@page "/changepassword"
@layout AuthLayout
@attribute [ExcludeFromInteractiveRouting]
@using System.Security.Claims
@inject NavigationManager Nav

<MudText Typo="Typo.h4">Change password</MudText>
<MudText Typo="Typo.body1">Update your account password below.</MudText>

@if (_success)
{
    <div class="al-alert-success">Password updated successfully.</div>
}

@if (_error is not null)
{
    <div class="al-alert-error">@_error</div>
}

<EditForm method="post" Model="Input" OnValidSubmit="HandleChange" FormName="ChangeForm">
    <DataAnnotationsValidator />

    <MudTextField @bind-Value="Input.CurrentPassword"
                  Label="Current password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_currentType"
                  Required="true"
                  RequiredError="Current password is required."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_currentIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="ToggleCurrent"
                  For="() => Input.CurrentPassword"
                  Class="mb-3" />

    <MudTextField @bind-Value="Input.NewPassword"
                  Label="New password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_newType"
                  Required="true"
                  RequiredError="New password is required."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_newIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="ToggleNew"
                  For="() => Input.NewPassword"
                  Class="mb-3" />

    <MudTextField @bind-Value="Input.ConfirmPassword"
                  Label="Confirm new password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_confirmType"
                  Required="true"
                  RequiredError="Please confirm your new password."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_confirmIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="ToggleConfirm"
                  For="() => Input.ConfirmPassword"
                  Class="mb-3" />

    <button type="submit" class="al-btn-primary">Update password</button>
    <a href="/profile" class="al-btn-outline">← Back to profile</a>
</EditForm>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "ChangeForm")]
    public ChangeInput Input { get; set; } = new();

    private bool    _success;
    private string? _error;

    private bool _showCurrent, _showNew, _showConfirm;

    private InputType _currentType => _showCurrent ? InputType.Text : InputType.Password;
    private string    _currentIcon => _showCurrent ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType _newType     => _showNew     ? InputType.Text : InputType.Password;
    private string    _newIcon     => _showNew     ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;
    private InputType _confirmType => _showConfirm ? InputType.Text : InputType.Password;
    private string    _confirmIcon => _showConfirm ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility;

    private void ToggleCurrent() => _showCurrent = !_showCurrent;
    private void ToggleNew()     => _showNew     = !_showNew;
    private void ToggleConfirm() => _showConfirm = !_showConfirm;

    protected override void OnInitialized()
    {
        if (HttpContext.User.Identity?.IsAuthenticated != true)
            Nav.NavigateTo("/login?returnUrl=/changepassword", forceLoad: true);
    }

    private async Task HandleChange()
    {
        var idStr = HttpContext.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!int.TryParse(idStr, out var userId)) { Nav.NavigateTo("/login", forceLoad: true); return; }

        var users     = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.UserService>();
        var user      = await users.FindByIdAsync(userId);
        if (user is null) { Nav.NavigateTo("/login", forceLoad: true); return; }

        var (ok, err) = await users.ChangePasswordAsync(user, Input.CurrentPassword, Input.NewPassword);

        if (!ok) { _error = err; return; }

        _success = true;
        Input    = new ChangeInput();
    }

    public class ChangeInput
    {
        [Required(ErrorMessage = "Current password is required.")]
        public string CurrentPassword { get; set; } = "";

        [Required(ErrorMessage = "New password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your new password.")]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
