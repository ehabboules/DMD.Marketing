@page "/onboarding"
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject ProvisioningService ProvisioningService

<PageTitle>Set Up Your Store — DMD Inventory</PageTitle>

<div class="ob-page">

    @if (_loading)
    {
        <div class="ob-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </div>
    }
    else if (_submitted)
    {
        <!-- ── Success screen ── -->
        <div class="ob-success-card">
            <div class="ob-success-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" width="32" height="32">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h1 class="ob-success-title">You're all set!</h1>
            <p class="ob-success-sub">
                Your store setup request has been received. Our team will provision your DMD StockShopOnline
                instance and email you login credentials within <strong>24 hours</strong>.
                Your <strong>14-day free trial</strong> starts now — trial ends on
                <strong>@_trialExpiresAt.ToString("MMMM d, yyyy")</strong>.
            </p>
            <div class="ob-success-steps">
                <div class="ob-step ob-step--done"><span class="ob-step-num">1</span><span>Request received</span></div>
                <div class="ob-step-arrow">→</div>
                <div class="ob-step"><span class="ob-step-num">2</span><span>We provision your DB</span></div>
                <div class="ob-step-arrow">→</div>
                <div class="ob-step"><span class="ob-step-num">3</span><span>Email with credentials</span></div>
                <div class="ob-step-arrow">→</div>
                <div class="ob-step"><span class="ob-step-num">4</span><span>Start selling</span></div>
            </div>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick='() => Nav.NavigateTo("/profile")'
                       Style="margin-top:1.5rem;font-weight:700;border-radius:10px;padding:12px 32px;">
                Back to Profile
            </MudButton>
        </div>
    }
    else
    {
        <!-- ── Wizard header ── -->
        <div class="ob-header">
            <div class="ob-eyebrow">Get started · 14-day free trial</div>
            <h1 class="ob-title">Set up your store</h1>
            <p class="ob-sub">A few details and your instance will be ready within 24 hours.</p>
        </div>

        <!-- ── Step indicators ── -->
        <div class="ob-steps-bar">
            @for (int i = 1; i <= 4; i++)
            {
                var step = i;
                <div class="ob-step-indicator @(step == _step ? "active" : step < _step ? "done" : "")">
                    <div class="ob-step-circle">
                        @if (step < _step)
                        {
                            <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" width="12" height="12">
                                <polyline points="2 7 5.5 10.5 12 4"/>
                            </svg>
                        }
                        else
                        {
                            @step
                        }
                    </div>
                    <span class="ob-step-label">@_stepLabels[step - 1]</span>
                </div>
                @if (i < 4)
                {
                    <div class="ob-step-connector @(step < _step ? "done" : "")"></div>
                }
            }
        </div>

        <!-- ── Step content ── -->
        <div class="ob-card">

            <!-- ════════════════ STEP 1 — Store details ════════════════ -->
            @if (_step == 1)
            {
                <h2 class="ob-card-title">Store details</h2>

                @if (_error is { Length: > 0 })
                {
                    <div class="ob-alert-error">@_error</div>
                }

                <div class="ob-fields">
                    <div class="ob-field-group ob-field-group--full">
                        <label class="ob-label">Store / Company name <span class="ob-required">*</span></label>
                        <input class="ob-input @(_showValidation && string.IsNullOrWhiteSpace(_storeName) ? "ob-input--error" : "")"
                               @bind="_storeName" placeholder="e.g. Maple Leaf Groceries" />
                        @if (_showValidation && string.IsNullOrWhiteSpace(_storeName))
                        {
                            <span class="ob-field-error">Store name is required</span>
                        }
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Business type <span class="ob-required">*</span></label>
                        <select class="ob-select @(_showValidation && string.IsNullOrWhiteSpace(_businessType) ? "ob-input--error" : "")"
                                @bind="_businessType">
                            <option value="">Select type…</option>
                            <option value="Retail">Retail / Phone Shop</option>
                            <option value="Grocery">Grocery / Supermarket</option>
                            <option value="Restaurant">Restaurant / Café</option>
                            <option value="Other">Other</option>
                        </select>
                        @if (_showValidation && string.IsNullOrWhiteSpace(_businessType))
                        {
                            <span class="ob-field-error">Business type is required</span>
                        }
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Phone <span class="ob-required">*</span></label>
                        <input class="ob-input @(_showValidation && string.IsNullOrWhiteSpace(_storePhone) ? "ob-input--error" : "")"
                               @bind="_storePhone" placeholder="+1 (416) 555-0100" />
                        @if (_showValidation && string.IsNullOrWhiteSpace(_storePhone))
                        {
                            <span class="ob-field-error">Phone is required</span>
                        }
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Timezone</label>
                        <select class="ob-select" @bind="_storeTimezone">
                            <option value="">Select timezone…</option>
                            <option value="Newfoundland Standard Time">Newfoundland (UTC-3:30)</option>
                            <option value="Atlantic Standard Time">Atlantic (UTC-4) — Halifax</option>
                            <option value="Eastern Standard Time">Eastern (UTC-5) — Toronto</option>
                            <option value="Central Standard Time">Central (UTC-6) — Winnipeg</option>
                            <option value="Mountain Standard Time">Mountain (UTC-7) — Calgary</option>
                            <option value="Pacific Standard Time">Pacific (UTC-8) — Vancouver</option>
                            <option value="GMT Standard Time">London / Dublin (UTC+0)</option>
                            <option value="Central European Standard Time">Central Europe (UTC+1)</option>
                            <option value="Egypt Standard Time">Cairo (UTC+2)</option>
                            <option value="Arab Standard Time">Kuwait / Riyadh (UTC+3)</option>
                            <option value="Arabian Standard Time">Dubai / Abu Dhabi (UTC+4)</option>
                        </select>
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Province</label>
                        <select class="ob-select" @bind="_province">
                            <option value="">Select province…</option>
                            <option value="AB">Alberta</option>
                            <option value="BC">British Columbia</option>
                            <option value="MB">Manitoba</option>
                            <option value="NB">New Brunswick</option>
                            <option value="NL">Newfoundland &amp; Labrador</option>
                            <option value="NS">Nova Scotia</option>
                            <option value="NT">Northwest Territories</option>
                            <option value="NU">Nunavut</option>
                            <option value="ON">Ontario</option>
                            <option value="PE">Prince Edward Island</option>
                            <option value="QC">Quebec</option>
                            <option value="SK">Saskatchewan</option>
                            <option value="YT">Yukon</option>
                        </select>
                    </div>
                </div>

                <div class="ob-actions">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="NextStep"
                               Style="font-weight:700;border-radius:10px;padding:12px 36px;">
                        Continue
                    </MudButton>
                </div>
            }

            <!-- ════════════════ STEP 2 — Store defaults ════════════════ -->
            else if (_step == 2)
            {
                <h2 class="ob-card-title">Store defaults</h2>
                <p class="ob-step-sub">These settings will pre-configure your StockShopOnline instance. You can change them anytime inside the app.</p>

                <div class="ob-fields">
                    <div class="ob-field-group">
                        <label class="ob-label">Currency</label>
                        <select class="ob-select" @bind="_currency">
                            <optgroup label="North America">
                                <option value="CAD">CAD – Canadian Dollar (CA$)</option>
                                <option value="USD">USD – US Dollar ($)</option>
                            </optgroup>
                            <optgroup label="Europe">
                                <option value="EUR">EUR – Euro (€)</option>
                                <option value="GBP">GBP – British Pound (£)</option>
                            </optgroup>
                            <optgroup label="Middle East &amp; Egypt">
                                <option value="EGP">EGP – Egyptian Pound (E£)</option>
                                <option value="SAR">SAR – Saudi Riyal</option>
                                <option value="AED">AED – UAE Dirham</option>
                                <option value="KWD">KWD – Kuwaiti Dinar</option>
                                <option value="QAR">QAR – Qatari Riyal</option>
                            </optgroup>
                        </select>
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Tax inclusive pricing</label>
                        <div class="ob-toggle-row">
                            <button class="ob-toggle @(_taxInclusive ? "on" : "")"
                                    type="button"
                                    @onclick="() => _taxInclusive = !_taxInclusive">
                                <span class="ob-toggle-knob"></span>
                            </button>
                            <span class="ob-toggle-label">
                                @(_taxInclusive ? "Prices include tax" : "Tax added on top of price")
                            </span>
                        </div>
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Federal tax rate (%)</label>
                        <input class="ob-input" type="number" min="0" max="100" step="0.01"
                               @bind="_federalTaxRate" placeholder="e.g. 5" />
                        <span class="ob-field-hint">GST in Canada is 5%</span>
                    </div>

                    <div class="ob-field-group">
                        <label class="ob-label">Provincial tax rate (%)</label>
                        <input class="ob-input" type="number" min="0" max="100" step="0.01"
                               @bind="_provincialTaxRate" placeholder="e.g. 9.975" />
                        <span class="ob-field-hint">QC: 9.975% · ON: 8% · BC: 7%</span>
                    </div>
                </div>

                <div class="ob-tax-info">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14" style="flex-shrink:0;color:#00897B"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
                    Combined rate applied at POS: <strong>@((_federalTaxRate + _provincialTaxRate).ToString("F2"))%</strong>
                </div>

                <div class="ob-actions">
                    <button class="ob-btn-back" @onclick="() => { _step = 1; _showValidation = false; }">← Back</button>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="NextStep"
                               Style="font-weight:700;border-radius:10px;padding:12px 36px;">
                        Continue
                    </MudButton>
                </div>
            }

            <!-- ════════════════ STEP 3 — Confirm plan ════════════════ -->
            else if (_step == 3)
            {
                <h2 class="ob-card-title">Confirm your plan</h2>

                <div class="ob-plan-card">
                    <div class="ob-plan-name">@_planDef?.Name</div>
                    <div class="ob-plan-billing">
                        @if (_planDef?.CustomPrice == true)
                        {
                            <span class="ob-plan-price">Custom pricing</span>
                        }
                        else
                        {
                            var price = _isAnnual ? _planDef?.AnnualPrice : _planDef?.MonthlyPrice;
                            <span class="ob-plan-price">$@price<span class="ob-plan-per">/mo</span></span>
                            @if (_isAnnual)
                            {
                                <span class="ob-plan-note">· billed annually</span>
                            }
                        }
                    </div>
                    <div class="ob-plan-cycle-badge @(_isAnnual ? "annual" : "monthly")">
                        @(_isAnnual ? "Annual billing · save 20%" : "Monthly billing")
                    </div>
                </div>

                <div class="ob-trial-banner">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/></svg>
                    <span>Your <strong>14-day free trial</strong> starts today. No charge until your instance is live and you decide to continue.</span>
                </div>

                <div class="ob-next-steps">
                    <h3 class="ob-next-title">What happens next</h3>
                    <ol class="ob-next-list">
                        <li>Your provisioning request is sent to our team</li>
                        <li>We spin up a dedicated database instance for your store</li>
                        <li>You receive an email with your login URL and credentials</li>
                        <li>Log in and start your 14-day trial — usually within 24 hours</li>
                    </ol>
                </div>

                <div class="ob-actions">
                    <button class="ob-btn-back" @onclick="() => _step = 2">← Back</button>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="NextStep"
                               Style="font-weight:700;border-radius:10px;padding:12px 36px;">
                        Looks good — activate
                    </MudButton>
                </div>
            }

            <!-- ════════════════ STEP 4 — Activate ════════════════ -->
            else if (_step == 4)
            {
                <h2 class="ob-card-title">Review &amp; submit</h2>
                <p class="ob-activate-sub">Double-check everything below, then submit your request.</p>

                <div class="ob-summary">
                    <div class="ob-summary-section">Store</div>
                    <div class="ob-summary-row"><span>Store name</span><strong>@_storeName</strong></div>
                    <div class="ob-summary-row"><span>Business type</span><strong>@_businessType</strong></div>
                    <div class="ob-summary-row"><span>Phone</span><strong>@_storePhone</strong></div>
                    @if (!string.IsNullOrWhiteSpace(_storeTimezone))
                    {
                        <div class="ob-summary-row"><span>Timezone</span><strong>@_storeTimezone</strong></div>
                    }
                    <div class="ob-summary-section">Defaults</div>
                    <div class="ob-summary-row"><span>Currency</span><strong>@_currency</strong></div>
                    <div class="ob-summary-row"><span>Federal tax</span><strong>@_federalTaxRate.ToString("F2")%</strong></div>
                    <div class="ob-summary-row"><span>Provincial tax</span><strong>@_provincialTaxRate.ToString("F2")%</strong></div>
                    <div class="ob-summary-row"><span>Tax inclusive</span><strong>@(_taxInclusive ? "Yes" : "No")</strong></div>
                    <div class="ob-summary-section">Plan</div>
                    <div class="ob-summary-row"><span>Plan</span><strong>@_planDef?.Name (@(_isAnnual ? "Annual" : "Monthly"))</strong></div>
                    <div class="ob-summary-row"><span>Trial ends</span><strong>@DateTime.UtcNow.AddDays(14).ToString("MMMM d, yyyy")</strong></div>
                </div>

                @if (_activationError is { Length: > 0 })
                {
                    <div class="ob-alert-error">@_activationError</div>
                }

                <div class="ob-actions">
                    <button class="ob-btn-back" @onclick="() => _step = 3" disabled="@_activating">← Back</button>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="Activate"
                               Disabled="_activating"
                               Style="font-weight:700;border-radius:10px;padding:12px 36px;">
                        @(_activating ? "Submitting…" : "Start my trial")
                    </MudButton>
                </div>
            }

        </div>
    }

</div>

@code {
    private User?   _user;
    private bool    _loading    = true;
    private int     _step       = 1;
    private bool    _submitted  = false;
    private bool    _activating = false;
    private bool    _showValidation = false;
    private string? _error;
    private string? _activationError;
    private DateTime _trialExpiresAt;

    // Step 1 fields
    private string? _storeName;
    private string? _businessType;
    private string? _storePhone;
    private string? _storeTimezone;
    private string? _province;

    // Step 2 fields
    private string  _currency          = "CAD";
    private decimal _federalTaxRate    = 5m;
    private decimal _provincialTaxRate = 0m;
    private bool    _taxInclusive      = false;

    private readonly string[] _stepLabels = { "Store details", "Store defaults", "Confirm plan", "Activate" };

    private record PlanDef(PlanSlug Slug, string Name, int MonthlyPrice, int AnnualPrice, bool CustomPrice);
    private readonly List<PlanDef> _planDefs = new()
    {
        new(PlanSlug.Starter,    "Starter",    49,  39,  false),
        new(PlanSlug.Growth,     "Growth",     99,  79,  false),
        new(PlanSlug.Pro,        "Pro",        179, 143, false),
        new(PlanSlug.Enterprise, "Enterprise", 0,   0,   true),
    };

    private PlanDef? _planDef;
    private bool     _isAnnual;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login?returnUrl=onboarding", forceLoad: false);
            return;
        }

        var idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(idStr, out var userId))
            _user = await Db.Users.FindAsync(userId);

        if (_user is null) { Nav.NavigateTo("/profile", forceLoad: false); return; }
        if (_user.ActivationStatus != ActivationStatus.None) { Nav.NavigateTo("/profile", forceLoad: false); return; }
        if (_user.SelectedPlan == PlanSlug.None) { Nav.NavigateTo("/profile", forceLoad: false); return; }

        _planDef  = _planDefs.FirstOrDefault(p => p.Slug == _user.SelectedPlan);
        _isAnnual = _user.BillingCycle == BillingCycle.Annual;

        // Pre-fill from previously saved data
        _storeName        = _user.StoreName;
        _storePhone       = _user.StorePhone;
        _storeTimezone    = _user.StoreTimezone;
        _businessType     = _user.BusinessType;
        _currency         = _user.Currency ?? "CAD";
        _federalTaxRate   = _user.FederalTaxRate;
        _provincialTaxRate = _user.ProvincialTaxRate;
        _taxInclusive     = _user.TaxInclusive;

        _trialExpiresAt = DateTime.UtcNow.AddDays(14);
        _loading = false;
    }

    private void NextStep()
    {
        if (_step == 1)
        {
            _showValidation = true;
            if (string.IsNullOrWhiteSpace(_storeName) || string.IsNullOrWhiteSpace(_businessType) || string.IsNullOrWhiteSpace(_storePhone))
                return;
            _showValidation = false;
            _step = 2;
        }
        else if (_step == 2)
        {
            _step = 3;
        }
        else if (_step == 3)
        {
            _step = 4;
        }
    }

    private async Task Activate()
    {
        if (_user is null) return;
        _activating      = true;
        _activationError = null;

        var success = await ProvisioningService.RequestActivationAsync(
            email:             _user.Email,
            firstName:         _user.FirstName ?? "",
            lastName:          _user.LastName  ?? "",
            planSlug:          _user.SelectedPlan.ToString(),
            billingCycle:      _isAnnual ? "Annual" : "Monthly",
            storeName:         _storeName!,
            storePhone:        _storePhone,
            storeTimezone:     _storeTimezone,
            businessType:      _businessType,
            currency:          _currency,
            federalTaxRate:    _federalTaxRate,
            provincialTaxRate: _provincialTaxRate,
            taxInclusive:      _taxInclusive,
            marketingUserId:   _user.Id);

        if (success)
        {
            var expiresAt = DateTime.UtcNow.AddDays(14);

            _user.StoreName             = _storeName?.Trim();
            _user.StorePhone            = _storePhone?.Trim();
            _user.StoreTimezone         = _storeTimezone;
            _user.BusinessType          = _businessType;
            _user.Currency              = _currency;
            _user.FederalTaxRate        = _federalTaxRate;
            _user.ProvincialTaxRate     = _provincialTaxRate;
            _user.TaxInclusive          = _taxInclusive;
            _user.ActivationStatus      = ActivationStatus.Pending;
            _user.SubscriptionExpiresAt = expiresAt;
            _user.ModifiedAt            = DateTime.UtcNow;
            await Db.SaveChangesAsync();

            _trialExpiresAt = expiresAt;
            _submitted = true;
        }
        else
        {
            _activationError = "Could not submit your request. Please try again or contact support.";
        }

        _activating = false;
    }
}

<style>
    .ob-page {
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
    }

    .ob-loading {
        display: flex; justify-content: center; padding: 5rem;
    }

    /* ── Header ── */
    .ob-eyebrow {
        display: inline-flex; align-items: center;
        background: #E0F7F4; color: #00695C;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.08em;
        padding: 4px 12px; border-radius: 20px;
        margin-bottom: 0.75rem;
    }
    .ob-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem; font-weight: 800;
        color: #1A237E; margin: 0 0 0.5rem;
    }
    .ob-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem; color: #6B7280; margin: 0 0 2rem;
    }

    /* ── Steps bar ── */
    .ob-steps-bar {
        display: flex; align-items: center;
        margin-bottom: 2rem; gap: 0;
    }
    .ob-step-indicator {
        display: flex; align-items: center; gap: 8px; flex-shrink: 0;
    }
    .ob-step-circle {
        width: 28px; height: 28px; border-radius: 50%;
        border: 2px solid #D1D5DB;
        background: #fff; color: #9CA3AF;
        display: flex; align-items: center; justify-content: center;
        font-family: 'Syne', sans-serif; font-size: 0.78rem; font-weight: 700;
        transition: all 0.2s;
    }
    .ob-step-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem; color: #9CA3AF; font-weight: 500;
        white-space: nowrap;
    }
    .ob-step-indicator.active .ob-step-circle { border-color: #00BFA5; background: #00BFA5; color: #fff; }
    .ob-step-indicator.active .ob-step-label  { color: #1C1C1E; font-weight: 700; }
    .ob-step-indicator.done .ob-step-circle   { border-color: #00897B; background: #00897B; color: #fff; }
    .ob-step-indicator.done .ob-step-label    { color: #6B7280; }
    .ob-step-connector {
        flex: 1; height: 2px; background: #E5E7EB;
        margin: 0 8px; min-width: 12px; transition: background 0.2s;
    }
    .ob-step-connector.done { background: #00897B; }

    /* ── Card ── */
    .ob-card {
        background: #fff; border: 1px solid #E5E7EB;
        border-radius: 16px; padding: 2rem;
    }
    .ob-card-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem; font-weight: 700;
        color: #1A237E; margin: 0 0 0.5rem;
    }
    .ob-step-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem; color: #6B7280;
        margin: 0 0 1.5rem; line-height: 1.55;
    }

    /* ── Fields ── */
    .ob-fields {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 1rem; margin-bottom: 1.25rem;
    }
    .ob-field-group { display: flex; flex-direction: column; gap: 6px; }
    .ob-field-group--full { grid-column: 1 / -1; }

    .ob-label {
        font-size: 0.78rem; font-weight: 600; color: #607D8B;
        text-transform: uppercase; letter-spacing: 0.06em;
    }
    .ob-required { color: #E53935; }
    .ob-field-hint { font-size: 0.72rem; color: #9CA3AF; }

    .ob-input, .ob-select {
        padding: 10px 14px;
        border: 1px solid #E5E7EB; border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
