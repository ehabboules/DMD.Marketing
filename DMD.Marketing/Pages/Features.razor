@page "/features"
@using Microsoft.AspNetCore.Components

<PageTitle>Features — DMD StockShopOnline</PageTitle>

<div class="features-hero">
    <div class="hero-inner">
        <div class="hero-eyebrow">Everything you need</div>
        <h1 class="hero-title">Built for Canadian retail.<br />End to end.</h1>
        <p class="hero-sub">From the moment a customer walks in to your monthly financial close — DMD handles it all in one platform.</p>
    </div>
</div>

<div class="features-page">

    <section class="feature-section" id="pos">
        <div class="section-header">
            <div class="section-icon pos-icon">
                <MudIcon Icon="@Icons.Material.Filled.PointOfSale" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Point of Sale</h2>
                <p class="section-desc">A fast, flexible POS that keeps up with your busiest hours.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>POS Terminal</h3>
                <p>Lightning-fast product search, cart management, order-level and item-level discounts, age restriction warnings, and notes. Supports Cash, Card, and Stripe Terminal.</p>
            </div>
            <div class="feat-card">
                <h3>Returns & Refunds</h3>
                <p>Select any past order, choose items to return, and stock is automatically restored. Orders are marked Refunded or Partial — no manual adjustments needed.</p>
            </div>
            <div class="feat-card">
                <h3>Cash Session Management</h3>
                <p>Open and close sessions per register with opening float and closing count. View active sessions at a glance, with full session history.</p>
            </div>
            <div class="feat-card">
                <h3>Multiple Registers</h3>
                <p>Add, edit, and assign as many cash registers as your locations need. Each register tracks its own sessions independently.</p>
            </div>
            <div class="feat-card">
                <h3>Canadian Tax Engine</h3>
                <p>Federal GST and provincial PST applied per product, per province. Tax logic is built in — not bolted on.</p>
            </div>
            <div class="feat-card">
                <h3>Stripe Terminal</h3>
                <p>Card-present payments via Stripe Reader. Semi-integrated setup keeps your workflow fast and your hardware costs low.</p>
            </div>
        </div>
    </section>

    <section class="feature-section alt" id="inventory">
        <div class="section-header">
            <div class="section-icon inv-icon">
                <MudIcon Icon="@Icons.Material.Filled.Inventory" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Inventory Management</h2>
                <p class="section-desc">Real-time stock across every warehouse, with a full audit trail.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Products</h3>
                <p>Add products with images, pricing, categories, tax settings, and age restrictions. Supports whole or decimal quantities depending on your business type.</p>
            </div>
            <div class="feat-card">
                <h3>Multi-Warehouse Stock</h3>
                <p>View stock levels across all your warehouses in one screen. Filter by location or status, make manual adjustments, and export to Excel.</p>
            </div>
            <div class="feat-card">
                <h3>Stock Movements Log</h3>
                <p>Every in and out movement is logged with a reference number, timestamp, and source. Your inventory is always explainable.</p>
            </div>
            <div class="feat-card">
                <h3>Low Stock Alerts</h3>
                <p>Dashboard surfaces low-stock counts instantly. Know what needs reordering before your shelves run dry.</p>
            </div>
            <div class="feat-card">
                <h3>Categories</h3>
                <p>Organize products into categories for faster search, cleaner reports, and better POS navigation.</p>
            </div>
            <div class="feat-card">
                <h3>Product Images</h3>
                <p>Upload product photos stored securely on Cloudflare R2. Images appear in POS search results for faster identification.</p>
            </div>
        </div>
    </section>

    <section class="feature-section" id="purchases">
        <div class="section-header">
            <div class="section-icon pur-icon">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Purchasing</h2>
                <p class="section-desc">Streamline your supplier relationships and stock replenishment.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Purchase Orders</h3>
                <p>Create, edit, and manage POs with a Draft → Ordered → Received status flow. Filter, search, and export to Excel.</p>
            </div>
            <div class="feat-card">
                <h3>Receive Stock</h3>
                <p>Two-step receiving workflow: select a PO, enter received quantities. Inventory updates automatically and last purchase costs are tracked per product.</p>
            </div>
            <div class="feat-card">
                <h3>Suppliers</h3>
                <p>Maintain a full supplier directory with contact details. Supplier history is linked directly to your purchase orders.</p>
            </div>
            <div class="feat-card">
                <h3>Last Purchase Cost</h3>
                <p>Always know what you last paid. Cost hints appear inline when creating new POs so you can spot pricing changes immediately.</p>
            </div>
        </div>
    </section>

    <section class="feature-section alt" id="sales">
        <div class="section-header">
            <div class="section-icon sal-icon">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Sales</h2>
                <p class="section-desc">Customer orders, promotions, and everything in between.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Sales Orders</h3>
                <p>Create and manage sales orders with customer selection, line items, specials auto-apply, and full totals. Export to Excel with one click.</p>
            </div>
            <div class="feat-card">
                <h3>Customers</h3>
                <p>Maintain a customer directory tied to your sales history. Add, edit, and remove customers with full order traceability.</p>
            </div>
            <div class="feat-card">
                <h3>Specials & Promotions</h3>
                <p>3-step wizard to create promotions: set the info, choose products, define the discount (fixed amount or percentage). Promotions auto-apply at POS and on sales orders.</p>
            </div>
            <div class="feat-card">
                <h3>Print Specials</h3>
                <p>Generate a printable special sheet directly from any promotion. Useful for shelf labels, flyers, and in-store signage.</p>
            </div>
        </div>
    </section>

    <section class="feature-section" id="finance">
        <div class="section-header">
            <div class="section-icon fin-icon">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Finance & Expenses</h2>
                <p class="section-desc">Keep expenses organized and understand your bottom line.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Expense Tracking</h3>
                <p>Log business expenses by category and date. Filter and review spending over any period to understand where your money is going.</p>
            </div>
            <div class="feat-card">
                <h3>Expense Categories</h3>
                <p>Create custom categories to match how your business tracks costs — rent, utilities, supplies, labour, and more.</p>
            </div>
            <div class="feat-card">
                <h3>Payment Methods</h3>
                <p>Define and manage accepted payment methods for your store. Activate or deactivate methods as your needs change.</p>
            </div>
            <div class="feat-card">
                <h3>Financial Dashboard</h3>
                <p>Admin-only overview of revenue, total spend, and net income. Understand your profitability without needing a spreadsheet.</p>
            </div>
        </div>
    </section>

    <section class="feature-section alt" id="reports">
        <div class="section-header">
            <div class="section-icon rep-icon">
                <MudIcon Icon="@Icons.Material.Filled.Assessment" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Reporting</h2>
                <p class="section-desc">Answers when you need them, in the format you want.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Sales Transactions</h3>
                <p>View all transactions for Today, Yesterday, This Week, This Month, or any custom period. Drill into any order directly.</p>
            </div>
            <div class="feat-card">
                <h3>Net Income Report</h3>
                <p>Revenue minus expenses, broken down by period. Understand profitability without leaving the platform.</p>
            </div>
            <div class="feat-card">
                <h3>Product Profitability</h3>
                <p>See which products are your best margin performers and which are dragging you down.</p>
            </div>
            <div class="feat-card">
                <h3>Inventory Valuation</h3>
                <p>Know the current value of your stock at any point in time, based on last purchase costs across all warehouses.</p>
            </div>
            <div class="feat-card">
                <h3>Sales Summary</h3>
                <p>Aggregate view of units sold, revenue, discounts applied, and taxes collected over any date range.</p>
            </div>
            <div class="feat-card">
                <h3>Excel Exports</h3>
                <p>Export purchase orders, sales orders, and stock data to Excel. Your accountant will thank you.</p>
            </div>
        </div>
    </section>

    <section class="feature-section" id="platform">
        <div class="section-header">
            <div class="section-icon plt-icon">
                <MudIcon Icon="@Icons.Material.Filled.Settings" Style="font-size:22px;" />
            </div>
            <div>
                <h2 class="section-title">Platform & Access Control</h2>
                <p class="section-desc">Built for teams, franchises, and multi-location operators.</p>
            </div>
        </div>
        <div class="feature-grid">
            <div class="feat-card">
                <h3>Role-Based Access</h3>
                <p>Create roles, assign users, and control exactly which screens each role can see. Cashiers see POS; managers see reports; admins see everything.</p>
            </div>
            <div class="feat-card">
                <h3>Multi-Tenant Architecture</h3>
                <p>Each business runs in its own isolated database. Your data never touches another tenant's. Built for franchises and resellers.</p>
            </div>
            <div class="feat-card">
                <h3>Multi-Language</h3>
                <p>Full support for English (CA), French (CA), and Arabic (SA) with RTL layout. Built for Canada's diverse workforce.</p>
            </div>
            <div class="feat-card">
                <h3>Timezone-Aware</h3>
                <p>Every date and timestamp respects your configured timezone. Reports and sessions always reflect your local business hours.</p>
            </div>
            <div class="feat-card">
                <h3>System Settings</h3>
                <p>Configure store name, address, timezone, and business type. Whole vs decimal quantity display adapts to your industry automatically.</p>
            </div>
            <div class="feat-card">
                <h3>Audit Trail</h3>
                <p>Every record carries CreatedAt, CreatedBy, ModifiedAt, and ModifiedBy. Full accountability across your entire operation.</p>
            </div>
        </div>
    </section>

    <section class="features-cta">
        <h2>Ready to see it in action?</h2>
        <p>14-day free trial. No credit card required. Set up in minutes.</p>
        <div class="cta-buttons">
            <a href="/pricing" class="btn-primary">View pricing</a>
            <a href="/contact" class="btn-secondary">Talk to us</a>
        </div>
    </section>

</div>

<style>
    :root {
        --teal: #00BFA5;
        --teal-dark: #00897B;
        --teal-light: #E0F7F4;
        --navy: #1A237E;
        --navy-light: #E8EAF6;
        --text: #1C1C1E;
        --text-muted: #6B7280;
        --border: #E5E7EB;
        --surface: #F9FAFB;
        --white: #FFFFFF;
    }

    .features-hero {
        background: #FFFFFF;
        padding: 5rem 2rem 4rem;
        text-align: center;
        position: relative;
        overflow: hidden;
        border-bottom: 1px solid var(--border);
    }

    .features-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 60% 50% at 50% 100%, rgba(0,191,165,0.07) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-inner {
        position: relative;
        max-width: 680px;
        margin: 0 auto;
    }

    .hero-eyebrow {
        display: inline-block;
        background: var(--teal-light);
        color: var(--teal-dark);
        font-size: 0.78rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        padding: 0.35rem 1rem;
        border-radius: 20px;
        border: 1px solid rgba(0,191,165,0.25);
        margin-bottom: 1.25rem;
    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        color: var(--text);
        line-height: 1.15;
        margin: 0 0 1rem;
    }

    .hero-sub {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.65;
        margin: 0;
    }

    .features-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 1.5rem 4rem;
    }

    .feature-section {
        padding: 4rem 0;
        border-bottom: 1px solid var(--border);
    }

    .feature-section:last-of-type {
        border-bottom: none;
    }

    .section-header {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        margin-bottom: 2.5rem;
    }

    .section-icon {
        width: 46px;
        height: 46px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .pos-icon { background: var(--teal-light); color: var(--teal-dark); }
    .inv-icon { background: var(--navy-light); color: var(--navy); }
    .pur-icon { background: #FFF3E0; color: #E65100; }
    .sal-icon { background: #F3E5F5; color: #7B1FA2; }
    .fin-icon { background: #E8F5E9; color: #2E7D32; }
    .rep-icon { background: #E3F2FD; color: #1565C0; }
    .plt-icon { background: var(--teal-light); color: var(--teal-dark); }

    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 0.25rem;
    }

    .section-desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
    }

    .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
    }

    .feat-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.4rem 1.5rem;
        transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
    }

    .feat-card:hover {
        border-color: var(--teal);
        box-shadow: 0 4px 20px rgba(0,191,165,0.1);
        transform: translateY(-2px);
    }

    .feat-card h3 {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 0.6rem;
    }

    .feat-card p {
        font-size: 0.875rem;
        color: var(--text-muted);
        line-height: 1.65;
        margin: 0;
    }

    .features-cta {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 3.5rem 2rem;
        text-align: center;
        margin-top: 3rem;
    }

    .features-cta h2 {
        font-family: 'Syne', sans-serif;
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text);
        margin: 0 0 0.75rem;
    }

    .features-cta p {
        font-size: 1rem;
        color: var(--text-muted);
        margin: 0 0 2rem;
    }

    .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: var(--teal);
        color: #FFFFFF;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.2s;
    }

    .btn-primary:hover { background: var(--teal-dark); }

    .btn-secondary {
        background: var(--white);
        color: var(--text);
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        text-decoration: none;
        border: 1px solid var(--border);
        transition: border-color 0.2s, background 0.2s;
    }

    .btn-secondary:hover {
        border-color: var(--teal);
        background: var(--teal-light);
    }

    @@media (max-width: 640px) {
        .feature-grid { grid-template-columns: 1fr; }
        .section-header { flex-direction: column; }
    }
</style>
