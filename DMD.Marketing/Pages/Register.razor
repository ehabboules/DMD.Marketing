@page "/register"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]
@layout EmptyLayout
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject UserService UserSvc
@inject ITokenService TokenService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject ILogger<Register> Logger

<PageTitle>Create Account – DMD Inventory</PageTitle>

<style>
    .register-page-wrapper {
        min-height: 100vh;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .register-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        animation: slideIn 0.5s ease-out;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .register-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        text-align: center;
        color: white;
    }

    .register-logo {
        width: 60px;
        height: 60px;
        margin: 0 auto 1rem;
        display: block;
        background: transparent;
    }

    .register-body {
        padding: 2.5rem 2rem;
    }

    .back-to-landing {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e0e0e0;
    }
</style>

<div class="register-page-wrapper">
    <MudPaper Class="register-card" Elevation="0" Style="width: 100%; max-width: 580px;">
        <div class="register-header">
            <img src="/images/DMD_POS_scalable.svg" class="register-logo" alt="DMD POS" />
            <MudText Typo="Typo.h4" Style="font-weight: 700; margin-bottom: 0.5rem;">
                Join DMD Inventory
            </MudText>
            <MudText Typo="Typo.body1" Style="opacity: 0.9;">
                Create your account to get started
            </MudText>
        </div>

        <div class="register-body">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="mb-4">
                    @_errorMessage
                </MudAlert>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true" Class="mb-4">
                    @_successMessage
                </MudAlert>
            }

            <EditForm Model="@_model" OnValidSubmit="OnSubmitAsync">
                <DataAnnotationsValidator />

                <MudStack Spacing="3">
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.FirstName"
                                          Label="First Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="First name is required"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Person"
                                          AdornmentColor="Color.Primary"
                                          Disabled="@_isLoading"
                                          For="@(() => _model.FirstName)" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_model.LastName"
                                          Label="Last Name"
                                          Variant="Variant.Outlined"
                                          Required="true"
                                          RequiredError="Last name is required"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Person"
                                          AdornmentColor="Color.Primary"
                                          Disabled="@_isLoading"
                                          For="@(() => _model.LastName)" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="_model.Email"
                                  Label="Email Address"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Required="true"
                                  RequiredError="Email is required"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  AdornmentColor="Color.Primary"
                                  Disabled="@_isLoading"
                                  For="@(() => _model.Email)" />

                    <MudTextField Value="@_model.Password"
                                  ValueChanged="@((string v) => { _model.Password = v; CheckPasswordStrength(v); })"
                                  Label="Password"
                                  Variant="Variant.Outlined"
                                  InputType="@_passwordInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_passwordIcon"
                                  OnAdornmentClick="TogglePassword"
                                  AdornmentAriaLabel="Show/Hide Password"
                                  Required="true"
                                  RequiredError="Password is required"
                                  Disabled="@_isLoading"
                                  Immediate="true"
                                  For="@(() => _model.Password)" />

                    <MudTextField @bind-Value="_model.ConfirmPassword"
                                  Label="Confirm Password"
                                  Variant="Variant.Outlined"
                                  InputType="@_confirmInput"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@_confirmIcon"
                                  OnAdornmentClick="ToggleConfirm"
                                  AdornmentAriaLabel="Show/Hide Confirm Password"
                                  Required="true"
                                  RequiredError="Please confirm your password"
                                  Disabled="@_isLoading"
                                  HelperText="Must be at least 8 characters with uppercase, lowercase, number, and special character"
                                  Immediate="true"
                                  For="@(() => _model.ConfirmPassword)" />

                    @if (!string.IsNullOrEmpty(_model.Password))
                    {
                        <MudPaper Elevation="1" Class="pa-3">
                            <MudText Typo="Typo.subtitle2" GutterBottom="true">Password Strength</MudText>
                            <MudProgressLinear Color="@GetStrengthColor()"
                                               Value="@_passwordStrength"
                                               Size="Size.Large"
                                               Rounded="true"
                                               Class="mb-2" />
                            <MudText Typo="Typo.caption" Color="@GetStrengthColor()">@GetStrengthText()</MudText>
                            <MudStack Spacing="1" Class="mt-3">
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasMinLength ? Color.Success : Color.Inherit)"
                                         Icon="@(_hasMinLength ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    8+ characters
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasUpper ? Color.Success : Color.Inherit)"
                                         Icon="@(_hasUpper ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Uppercase letter
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasLower ? Color.Success : Color.Inherit)"
                                         Icon="@(_hasLower ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Lowercase letter
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasNumber ? Color.Success : Color.Inherit)"
                                         Icon="@(_hasNumber ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Number
                                </MudChip>
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                         Color="@(_hasSpecial ? Color.Success : Color.Inherit)"
                                         Icon="@(_hasSpecial ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.RadioButtonUnchecked)">
                                    Special character
                                </MudChip>
                            </MudStack>
                        </MudPaper>
                    }

                    <ValidationSummary />

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); font-weight: 600; margin-top: 1rem;"
                               Disabled="@_isLoading">
                        @if (_isLoading)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" Color="Color.Surface" />
                            <MudText Class="ms-2">Creating account…</MudText>
                        }
                        else
                        {
                            <MudText>Create Account</MudText>
                        }
                    </MudButton>
                </MudStack>
            </EditForm>

            <MudDivider Class="my-4" />

            <MudText Typo="Typo.body2" Align="Align.Center" Class="mb-3">
                Already have an account?
                <MudLink Href="/login" Color="Color.Primary" Style="font-weight: 600;">
                    Sign in here
                </MudLink>
            </MudText>

            <div class="back-to-landing">
                <MudLink Href="/" Color="Color.Inherit" Style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
                    <MudIcon Icon="@Icons.Material.Filled.ArrowBack" Size="Size.Small" />
                    Back to Landing Page
                </MudLink>
            </div>
        </div>
    </MudPaper>
</div>

@code {
    private RegisterModel _model = new();
    private bool _isLoading = false;
    private string? _errorMessage;
    private string? _successMessage;

    // Password visibility
    private bool _showPassword;
    private bool _showConfirm;
    private InputType _passwordInput => _showPassword ? InputType.Text : InputType.Password;
    private string   _passwordIcon   => _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    private InputType _confirmInput  => _showConfirm  ? InputType.Text : InputType.Password;
    private string   _confirmIcon    => _showConfirm  ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;

    private void TogglePassword() => _showPassword = !_showPassword;
    private void ToggleConfirm()  => _showConfirm  = !_showConfirm;

    // Password strength
    private double _passwordStrength;
    private bool _hasMinLength, _hasUpper, _hasLower, _hasNumber, _hasSpecial;

    private void CheckPasswordStrength(string pw)
    {
        _hasMinLength = pw.Length >= 8;
        _hasUpper     = pw.Any(char.IsUpper);
        _hasLower     = pw.Any(char.IsLower);
        _hasNumber    = pw.Any(char.IsDigit);
        _hasSpecial   = pw.Any(c => !char.IsLetterOrDigit(c));

        int count = (_hasMinLength ? 1 : 0) + (_hasUpper ? 1 : 0) + (_hasLower ? 1 : 0)
                  + (_hasNumber   ? 1 : 0) + (_hasSpecial ? 1 : 0);
        _passwordStrength = (count / 5.0) * 100;
    }

    private Color GetStrengthColor() => _passwordStrength switch
    {
        <= 0  => Color.Inherit,
        < 40  => Color.Error,
        < 60  => Color.Warning,
        < 80  => Color.Info,
        _     => Color.Success
    };

    private string GetStrengthText() => _passwordStrength switch
    {
        <= 0  => "No password entered",
        < 40  => "Weak – add more requirements",
        < 60  => "Fair – almost there",
        < 80  => "Good – consider all requirements",
        _     => "Strong – all requirements met"
    };

    private async Task OnSubmitAsync()
    {
        _errorMessage   = null;
        _successMessage = null;
        _isLoading      = true;

        try
        {
            if (_model.Password != _model.ConfirmPassword)
            {
                _errorMessage = "Passwords do not match.";
                Snackbar.Add(_errorMessage, Severity.Error);
                return;
            }

            if (_passwordStrength < 100)
            {
                _errorMessage = "Password does not meet all requirements.";
                Snackbar.Add(_errorMessage, Severity.Warning);
                return;
            }

            // Register directly via UserService
            var (user, error) = await UserSvc.CreateAsync(
                _model.Email, _model.FirstName, _model.LastName, _model.Password);

            if (user is null)
            {
                _errorMessage = error ?? "Registration failed.";
                Snackbar.Add(_errorMessage, Severity.Error);
                return;
            }

            Logger.LogInformation("Registration successful for {Email}, proceeding to auto-login", _model.Email);
            Snackbar.Add("Account created successfully! Logging you in…", Severity.Success);

            await Task.Delay(400);

            // Auto-login via /connect/token
            var loginContent = new FormUrlEncodedContent(new[]
            {
                new KeyValuePair<string?, string?>("grant_type", "password"),
                new KeyValuePair<string?, string?>("username",   _model.Email),
                new KeyValuePair<string?, string?>("password",   _model.Password),
                new KeyValuePair<string?, string?>("scope",      "openid email profile offline_access")
            });

            var http         = HttpClientFactory.CreateClient();
            var tokenUrl     = $"{Navigation.BaseUri}connect/token";
            var tokenResponse = await http.PostAsync(tokenUrl, loginContent);

            if (!tokenResponse.IsSuccessStatusCode)
            {
                Snackbar.Add("Account created but auto-login failed. Please log in manually.", Severity.Warning);
                await Task.Delay(2000);
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            var tokenJson = await tokenResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokenJson?.access_token != null)
            {
                await TokenService.SaveTokensAsync(tokenJson.access_token, tokenJson.refresh_token, tokenJson.expires_in);

                if (AuthStateProvider is CustomAuthStateProvider provider)
                    provider.NotifyAuthenticationStateChanged();

                await Task.Delay(100);

                _successMessage = "Account created and logged in! Redirecting…";
                Snackbar.Add(_successMessage, Severity.Success);
                await Task.Delay(400);
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                Snackbar.Add("Account created but auto-login failed. Please log in manually.", Severity.Warning);
                await Task.Delay(2000);
                Navigation.NavigateTo("/login", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"An error occurred: {ex.Message}";
            Snackbar.Add(_errorMessage, Severity.Error);
            Logger.LogError(ex, "Registration error for {Email}", _model.Email);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private class RegisterModel
    {
        [Required(ErrorMessage = "First name is required")]
        [MaxLength(100)]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Last name is required")]
        [MaxLength(100)]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email format")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = "";
    }
}
