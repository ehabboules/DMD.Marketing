@page "/register"
@layout AuthLayout
@attribute [ExcludeFromInteractiveRouting]
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@inject NavigationManager Nav

<MudText Typo="Typo.h4">Create your account</MudText>
<MudText Typo="Typo.body1">Start your 14-day free trial. No credit card required.</MudText>

@if (_error is not null)
{
    <div class="al-alert-error">@_error</div>
}

<EditForm method="post" Model="Input" OnValidSubmit="HandleRegister" FormName="RegisterForm">
    <DataAnnotationsValidator />

    <MudGrid Spacing="2">
        <MudItem xs="6">
            <MudTextField @bind-Value="Input.FirstName"
                          Placeholder="First name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Required="true"
                          RequiredError="First name is required."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          For="() => Input.FirstName"
                          Class="mb-3" />
        </MudItem>
        <MudItem xs="6">
            <MudTextField @bind-Value="Input.LastName"
                          Placeholder="Last name"
                          Variant="Variant.Outlined"
                          Margin="Margin.Normal"
                          Required="true"
                          RequiredError="Last name is required."
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          AdornmentColor="Color.Primary"
                          For="() => Input.LastName"
                          Class="mb-3" />
        </MudItem>
    </MudGrid>

    <MudTextField @bind-Value="Input.Email"
                  Placeholder="Email address"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="InputType.Email"
                  Required="true"
                  RequiredError="Email is required."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Email"
                  AdornmentColor="Color.Primary"
                  For="() => Input.Email"
                  Class="mb-3" />

    <MudTextField @bind-Value="Input.Password"
                  Label="Password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_passwordType"
                  Required="true"
                  RequiredError="Password is required."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_passwordIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="TogglePassword"
                  For="() => Input.Password"
                  Class="mb-3" />

    <MudTextField @bind-Value="Input.ConfirmPassword"
                  Label="Confirm password"
                  Variant="Variant.Outlined"
                  Margin="Margin.Normal"
                  InputType="@_confirmType"
                  Required="true"
                  RequiredError="Please confirm your password."
                  Adornment="Adornment.End"
                  AdornmentIcon="@_confirmIcon"
                  AdornmentColor="Color.Primary"
                  OnAdornmentClick="ToggleConfirm"
                  For="() => Input.ConfirmPassword"
                  Class="mb-3" />

    <button type="submit" class="al-btn-primary">Create account</button>

    <div class="al-links">
        Already have an account? <a href="/login">Sign in →</a>
    </div>
</EditForm>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm(FormName = "RegisterForm")]
    public RegisterInput Input { get; set; } = new();

    private string? _error;

    private bool      _showPassword;
    private bool      _showConfirm;
    private InputType _passwordType => _showPassword ? InputType.Text : InputType.Password;
    private string    _passwordIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;
    private InputType _confirmType  => _showConfirm  ? InputType.Text : InputType.Password;
    private string    _confirmIcon  => _showConfirm
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    private void TogglePassword() => _showPassword = !_showPassword;
    private void ToggleConfirm()  => _showConfirm  = !_showConfirm;

    public class RegisterInput
    {
        [Required(ErrorMessage = "First name is required.")]
        [MaxLength(100)]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Last name is required.")]
        [MaxLength(100)]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Password is required.")]
        [MinLength(8, ErrorMessage = "Password must be at least 8 characters.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = "";
    }

    private async Task HandleRegister()
    {
        var users         = HttpContext.RequestServices.GetRequiredService<DMD.Marketing.Services.UserService>();
        var (user, error) = await users.CreateAsync(Input.Email, Input.FirstName, Input.LastName, Input.Password);

        if (user is null) { _error = error; return; }

        var claims = new List<Claim>
        {
            new(ClaimTypes.NameIdentifier, user.Id.ToString()),
            new(ClaimTypes.Name,           user.Email),
            new(ClaimTypes.GivenName,      user.FirstName ?? ""),
            new(ClaimTypes.Surname,        user.LastName  ?? ""),
        };

        await HttpContext.SignInAsync(
            CookieAuthenticationDefaults.AuthenticationScheme,
            new ClaimsPrincipal(new ClaimsIdentity(claims, CookieAuthenticationDefaults.AuthenticationScheme)),
            new AuthenticationProperties { IsPersistent = true });

        Nav.NavigateTo("/profile", forceLoad: true);
    }
}
