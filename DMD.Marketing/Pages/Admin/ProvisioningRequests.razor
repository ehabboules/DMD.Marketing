@page "/admin/provisioning"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using DMD.Marketing.Services
@inject ProvisioningService ProvisioningService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">

    <!-- ── Header ─────────────────────────────────────────── -->
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIcon Icon="@Icons.Material.Filled.CloudQueue" Color="Color.Primary" Size="Size.Large" />
        <div>
            <MudText Typo="Typo.h4">Provisioning Requests</MudText>
            <MudText Typo="Typo.body2" Color="Color.Inherit">Manage store instance requests and billing</MudText>
        </div>
        <MudSpacer />
        <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                   Variant="Variant.Outlined"
                   Color="Color.Primary"
                   OnClick="LoadAsync"
                   Disabled="_loading">
            Refresh
        </MudButton>
    </MudStack>

    <!-- ── Stats ──────────────────────────────────────────── -->
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Total</MudText>
                        <MudText Typo="Typo.h4" Class="font-weight-bold">@_all.Count</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.List" Color="Color.Primary" Size="Size.Large" />
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Pending</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Warning" Class="font-weight-bold">@_all.Count(r => r.Status == "Pending")</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.HourglassEmpty" Color="Color.Warning" Size="Size.Large" />
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Provisioning</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Info" Class="font-weight-bold">@_all.Count(r => r.Status == "Provisioning")</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.SettingsApplications" Color="Color.Info" Size="Size.Large" />
                </MudStack>
            </MudPaper>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudPaper Elevation="2" Class="pa-3" Style="border-radius:12px;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">Active</MudText>
                        <MudText Typo="Typo.h4" Color="Color.Success" Class="font-weight-bold">@_all.Count(r => r.Status == "Active")</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                </MudStack>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- ── Filters ────────────────────────────────────────── -->
    <MudGrid Spacing="3" Class="mb-3">
        <MudItem xs="12" sm="5">
            <MudTextField @bind-Value="_search"
                          Placeholder="Search by store, name or email…"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          OnDebounceIntervalElapsed="Filter"
                          DebounceInterval="300"
                          Variant="Variant.Outlined"
                          Dense="true" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_filterStatus"
                       Label="Status"
                       T="string"
                       Clearable="true"
                       Variant="Variant.Outlined"
                       Dense="true"
                       OnClearButtonClick="@(() => { _filterStatus = null; Filter(); })">
                <MudSelectItem Value="@("Pending")">Pending</MudSelectItem>
                <MudSelectItem Value="@("Provisioning")">Provisioning</MudSelectItem>
                <MudSelectItem Value="@("Active")">Active</MudSelectItem>
                <MudSelectItem Value="@("Rejected")">Rejected</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>

    <!-- ── Table ──────────────────────────────────────────── -->
    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
    }
    else
    {
        <MudPaper Elevation="2" Style="border-radius:12px;overflow:hidden;">
            <MudTable Items="@_filtered" Hover="true" Dense="false" Elevation="0" Breakpoint="Breakpoint.Md">
                <HeaderContent>
                    <MudTh Style="font-weight:600;">Store</MudTh>
                    <MudTh Style="font-weight:600;">Contact</MudTh>
                    <MudTh Style="font-weight:600;">Plan</MudTh>
                    <MudTh Style="font-weight:600;">Defaults</MudTh>
                    <MudTh Style="font-weight:600;">Status</MudTh>
                    <MudTh Style="font-weight:600;">Requested</MudTh>
                    <MudTh Style="font-weight:600;">Expires</MudTh>
                    <MudTh Style="font-weight:600;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Store">
                        <MudText Typo="Typo.body2" Class="font-weight-medium">@context.StoreName</MudText>
                        @if (!string.IsNullOrEmpty(context.AppUrl))
                        {
                            <MudText Typo="Typo.caption">
                                <a href="@context.AppUrl" target="_blank" style="color:#00BFA5;">@context.AppUrl</a>
                            </MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Contact">
                        <MudText Typo="Typo.body2">@context.FirstName @context.LastName</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">@context.Email</MudText>
                    </MudTd>
                    <MudTd DataLabel="Plan">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">@context.PlanSlug</MudChip>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">@context.BillingCycle</MudText>
                    </MudTd>
                    <MudTd DataLabel="Defaults">
                        <MudText Typo="Typo.caption">@(context.Currency ?? "CAD")</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Inherit">
                            GST @context.FederalTaxRate.ToString("F1")% + QST @context.ProvincialTaxRate.ToString("F1")%
                        </MudText>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string"
                                 Color="@StatusColor(context.Status)"
                                 Size="Size.Small"
                                 Icon="@StatusIcon(context.Status)"
                                 Variant="Variant.Filled">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Requested">
                        <MudText Typo="Typo.body2">@context.RequestedAt.ToString("MMM d, yyyy")</MudText>
                    </MudTd>
                    <MudTd DataLabel="Expires">
                        @if (context.ExpiresAt.HasValue)
                        {
                            var days = (int)Math.Ceiling((context.ExpiresAt.Value - DateTime.UtcNow).TotalDays);
                            <MudText Typo="Typo.body2"
                                     Color="@(days <= 0 ? Color.Error : days <= 7 ? Color.Warning : Color.Inherit)">
                                @context.ExpiresAt.Value.ToString("MMM d, yyyy")
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Inherit">
                                @(days <= 0 ? "Expired" : $"{days}d left")
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Color="Color.Inherit">—</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Actions">
                        <MudTooltip Text="Edit request">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary" Size="Size.Medium"
                                           OnClick="@(() => OpenEditAsync(context))" />
                        </MudTooltip>
                        <MudTooltip Text="Record payment">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCard"
                                           Color="Color.Success" Size="Size.Medium"
                                           OnClick="@(() => OpenPaymentAsync(context))" />
                        </MudTooltip>
                    </MudTd>
                </RowTemplate>
                <NoRecordsContent>
                    <MudText Typo="Typo.body1" Align="Align.Center" Class="py-8">
                        No provisioning requests found.
                    </MudText>
                </NoRecordsContent>
            </MudTable>
        </MudPaper>
    }

</MudContainer>

@code {
    private List<ProvisioningRequestInfo> _all      = new();
    private List<ProvisioningRequestInfo> _filtered = new();
    private bool    _loading      = true;
    private string  _search       = "";
    private string? _filterStatus = null;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _all = await ProvisioningService.GetAllRequestsAsync();
        Filter();
        _loading = false;
    }

    private void Filter()
    {
        _filtered = _all.Where(r =>
        {
            bool matchSearch = string.IsNullOrWhiteSpace(_search) ||
                r.StoreName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                r.Email.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                r.FirstName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                r.LastName.Contains(_search, StringComparison.OrdinalIgnoreCase);

            bool matchStatus = string.IsNullOrWhiteSpace(_filterStatus) ||
                r.Status.Equals(_filterStatus, StringComparison.OrdinalIgnoreCase);

            return matchSearch && matchStatus;
        }).ToList();

        StateHasChanged();
    }

    private async Task OpenEditAsync(ProvisioningRequestInfo r)
    {
        var parameters = new DialogParameters<ProvisioningEditDialog> { { x => x.Request, r } };
        var options    = new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true };
        var dialog     = await DialogService.ShowAsync<ProvisioningEditDialog>("Edit Request", parameters, options);
        var result     = await dialog.Result;
        if (result is { Canceled: false }) await LoadAsync();
    }

    private async Task OpenPaymentAsync(ProvisioningRequestInfo r)
    {
        var parameters = new DialogParameters<RecordPaymentDialog> { { x => x.Request, r } };
        var options    = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true };
        var dialog     = await DialogService.ShowAsync<RecordPaymentDialog>("Record Payment", parameters, options);
        await dialog.Result;
    }

    private static Color StatusColor(string s) => s switch
    {
        "Pending"      => Color.Warning,
        "Provisioning" => Color.Info,
        "Active"       => Color.Success,
        "Rejected"     => Color.Error,
        _              => Color.Inherit
    };

    private static string StatusIcon(string s) => s switch
    {
        "Pending"      => Icons.Material.Filled.HourglassEmpty,
        "Provisioning" => Icons.Material.Filled.SettingsApplications,
        "Active"       => Icons.Material.Filled.CheckCircle,
        "Rejected"     => Icons.Material.Filled.Cancel,
        _              => Icons.Material.Filled.Help
    };
}
