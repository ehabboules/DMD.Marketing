@page "/profile"
@* @rendermode new InteractiveServerRenderMode(prerender: false)
 *@@* Correct syntax for component definition *@
@rendermode @(new InteractiveServerRenderMode(prerender: false))

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<PageTitle>My Profile — DMD Inventory</PageTitle>

<div class="profile-page">

    @if (_loading)
    {
        <div class="profile-loading">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
        </div>
    }
    else if (_user is null)
    {
        <MudAlert Severity="Severity.Error">Could not load your profile. Please try again.</MudAlert>
    }
    else
    {
        <!-- ── Header ── -->
        <div class="profile-header">
            <div class="profile-avatar">
                @(string.IsNullOrWhiteSpace(_user.FirstName) ? "?" : _user.FirstName[0].ToString().ToUpper())
            </div>
            <div>
                <h1 class="profile-name">@((_user.FirstName + " " + _user.LastName).Trim() is { Length: > 0 } n ? n : _user.Email)</h1>
                <p class="profile-email">@_user.Email</p>
            </div>
        </div>

        @if (_user.ActivationStatus == ActivationStatus.Active)
        {
            <div class="activation-banner activation-banner--active">
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                Your store is <strong>live</strong>! Check your email for login credentials.
            </div>
        }
        else if (_user.ActivationStatus == ActivationStatus.Pending)
        {
            <div class="activation-banner activation-banner--pending">
                <span class="activation-pending-dot"></span>
                Your store provisioning is <strong>in progress</strong>. We'll email you within 24 hours.
            </div>
        }

        <!-- ══════════════════════════════════════════════════
             § SUBSCRIPTION SUMMARY
        ═══════════════════════════════════════════════════ -->
        <div class="profile-section">
            <div class="section-header-row">
                <h2 class="section-title">Subscription</h2>
                @if (_user.ActivationStatus == ActivationStatus.Active)
                {
                    <span class="sub-status sub-status--active">
                        <span class="sub-status-dot"></span>Active
                    </span>
                }
                else if (_user.ActivationStatus == ActivationStatus.Pending)
                {
                    <span class="sub-status sub-status--pending">
                        <span class="sub-status-dot sub-status-dot--amber"></span>Pending
                    </span>
                }
                else if (_user.SelectedPlan != PlanSlug.None)
                {
                    <span class="sub-status sub-status--setup">
                        Setup required
                    </span>
                }
                else
                {
                    <span class="sub-status sub-status--none">No active plan</span>
                }
            </div>

            @if (_user.SelectedPlan != PlanSlug.None)
            {
                var planDef   = _plans.FirstOrDefault(p => p.Slug == _user.SelectedPlan);
                var isAnnual  = _user.BillingCycle == BillingCycle.Annual;
                var nextDate  = GetNextPaymentDate();
                var amount    = planDef is { CustomPrice: false }
                                    ? (isAnnual ? planDef.AnnualPrice : planDef.MonthlyPrice)
                                    : (int?)null;

                <div class="sub-grid">
                    <div class="sub-item">
                        <span class="sub-item-label">Current plan</span>
                        <span class="sub-item-value sub-plan-pill">
                            @planDef?.Name
                        </span>
                    </div>
                    <div class="sub-item">
                        <span class="sub-item-label">Billing cycle</span>
                        <span class="sub-item-value">@(isAnnual ? "Annual" : "Monthly")</span>
                    </div>
                    <div class="sub-item">
                        <span class="sub-item-label">
                            @(_user.ActivationStatus == ActivationStatus.Pending ? "Trial ends" : "Next payment")
                        </span>
                        <span class="sub-item-value sub-item-value--accent">
                            @if (_user.SubscriptionExpiresAt.HasValue)
                            {
                                @_user.SubscriptionExpiresAt.Value.ToString("MMM d, yyyy")
                            }
                            else
                            {
                                @(nextDate.HasValue ? nextDate.Value.ToString("MMM d, yyyy") : "—")
                            }
                        </span>
                    </div>
                    <div class="sub-item">
                        <span class="sub-item-label">Amount due</span>
                        <span class="sub-item-value">
                            @if (_user.ActivationStatus == ActivationStatus.Pending)
                            {
                                <span style="color:#00897B;font-size:0.85rem;">Free trial</span>
                            }
                            else
                            {
                                @(amount.HasValue ? $"${amount}/mo" : "Custom")
                                @if (isAnnual && amount.HasValue)
                                {
                                    <span class="sub-billed-note">&nbsp;· billed annually</span>
                                }
                            }
                        </span>
                    </div>
                </div>

                @if (_user.ActivationStatus != ActivationStatus.Active)
                {
                    <div class="sub-payment-cta">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CreditCard"
                                   Href="/payment">
                            Subscribe Now
                        </MudButton>
                    </div>
                }

                <!-- Cancel flow -->
                @if (_cancelSuccess)
                {
                    <div class="sub-cancel-success">
                        <svg viewBox="0 0 20 20" fill="currentColor" width="15" height="15"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                        Subscription cancelled. Access continues until @(nextDate?.ToString("MMM d, yyyy") ?? "end of period").
                    </div>
                }
                else if (_showCancelConfirm)
                {
                    <div class="sub-cancel-box">
                        <p class="sub-cancel-question">
                            Are you sure? You'll keep full access to <strong>@planDef?.Name</strong> until
                            <strong>@(nextDate?.ToString("MMM d, yyyy") ?? "end of period")</strong>, then your account will downgrade.
                        </p>
                        <div class="sub-cancel-actions">
                            <button class="btn-cancel-confirm"
                                    disabled="@_cancelling"
                                    @onclick="CancelSubscription">
                                @(_cancelling ? "Cancelling…" : "Yes, cancel subscription")
                            </button>
                            <button class="btn-cancel-dismiss"
                                    @onclick="() => _showCancelConfirm = false">
                                Keep my subscription
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn-cancel-sub" @onclick="() => _showCancelConfirm = true">
                        Cancel subscription
                    </button>
                }
            }
            else
            {
                <p class="sub-no-plan">
                    You don't have an active subscription. Choose a plan below to get started.
                </p>
            }
        </div>

        <!-- ── Account details ── -->
        <div class="profile-section">
            <h2 class="section-title">Account details</h2>
            <div class="fields-grid">
                <div class="field-group">
                    <label class="field-label">First name</label>
                    <input class="field-input" @bind="_firstName" placeholder="First name" />
                </div>
                <div class="field-group">
                    <label class="field-label">Last name</label>
                    <input class="field-input" @bind="_lastName" placeholder="Last name" />
                </div>
                <div class="field-group">
                    <label class="field-label">Email</label>
                    <input class="field-input" value="@_user.Email" disabled />
                </div>
            </div>
        </div>

        <!-- ── Plan selection ── -->
        <div class="profile-section">
            <div class="section-header-row">
                <h2 class="section-title">Change plan</h2>
                <div class="billing-toggle">
                    <span class="@(!_annual ? "toggle-label-active" : "toggle-label")">Monthly</span>
                    <button class="toggle-pill @(_annual ? "on" : "")"
                            @onclick="() => _annual = !_annual"
                            aria-label="Toggle billing">
                        <span class="toggle-knob"></span>
                    </button>
                    <span class="@(_annual ? "toggle-label-active" : "toggle-label")">Annual</span>
                    <span class="save-tag">Save 20%</span>
                </div>
            </div>

            <div class="plans-grid">
                @foreach (var plan in _plans)
                {
                    var isSelected = _selectedPlan == plan.Slug;
                    <div class="plan-card @(isSelected ? "plan-card--selected" : "") @(plan.Featured ? "plan-card--featured" : "")"
                         @onclick="() => SelectPlan(plan.Slug)">

                        @if (plan.Featured)
                        {
                            <div class="popular-tag">Most popular</div>
                        }

                        <div class="plan-check @(isSelected ? "plan-check--on" : "")">
                            @if (isSelected)
                            {
                                <svg viewBox="0 0 20 20" fill="currentColor" width="12" height="12"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                            }
                        </div>

                        <div class="plan-name">@plan.Name</div>
                        <div class="plan-desc">@plan.Description</div>

                        <div class="plan-price">
                            @if (plan.CustomPrice)
                            {
                                <span class="price-custom">Custom</span>
                            }
                            else
                            {
                                <span class="price-amount">$@(_annual ? plan.AnnualPrice : plan.MonthlyPrice)</span>
                                <span class="price-period">/mo</span>
                            }
                        </div>

                        <ul class="plan-features">
                            @foreach (var feat in plan.Highlights)
                            {
                                <li>
                                    <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.6" width="12" height="12"><polyline points="2 7 5.5 10.5 12 4"/></svg>
                                    @feat
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>

        <!-- ── Save button ── -->
        <div class="save-row">
            @if (_saveSuccess)
            {
                <div class="save-success-msg">
                    <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    Profile saved!
                </div>
            }
            @if (_saveError is { Length: > 0 })
            {
                <div class="save-error-msg">@_saveError</div>
            }
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       OnClick="SaveProfile"
                       Disabled="_saving"
                       Style="font-weight:700;border-radius:10px;padding:12px 36px;">
                @(_saving ? "Saving…" : "Save profile")
            </MudButton>
        </div>
    }

</div>

@code {
    // ── State ────────────────────────────────────────────────────────
    private User?   _user;
    private bool    _loading       = true;
    private bool    _saving        = false;
    private bool    _saveSuccess   = false;
    private string? _saveError;

    private string? _firstName;
    private string? _lastName;
    private bool     _annual       = false;
    private PlanSlug _selectedPlan = PlanSlug.None;

    // cancel flow
    private bool _showCancelConfirm = false;
    private bool _cancelling        = false;
    private bool _cancelSuccess     = false;

    // ── Plan definitions ─────────────────────────────────────────────
    private record PlanDef(
        PlanSlug Slug, string Name, string Description,
        int MonthlyPrice, int AnnualPrice, bool CustomPrice, bool Featured,
        List<string> Highlights);

    private readonly List<PlanDef> _plans = new()
    {
        new(PlanSlug.Starter, "Starter", "One location, getting off the ground.",
            49, 39, false, false,
            new() { "1 register", "1 warehouse · 500 products", "1 user", "Sales & inventory reports" }),

        new(PlanSlug.Growth, "Growth", "Scaling retail with full POS and reporting.",
            99, 79, false, true,
            new() { "2 registers", "3 warehouses · unlimited products", "5 users", "Financial dashboard", "Stripe Terminal" }),

        new(PlanSlug.Pro, "Pro", "Multi-location with full control and localization.",
            179, 143, false, false,
            new() { "Unlimited registers & warehouses", "Unlimited users", "Multi-language (EN/FR/AR)", "Everything in Growth" }),

        new(PlanSlug.Enterprise, "Enterprise", "Custom deployments and dedicated support.",
            0, 0, true, false,
            new() { "Everything in Pro", "Dedicated infrastructure", "Custom integrations", "SLA & priority support" }),
    };

    // ── Lifecycle ────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var auth  = await AuthStateProvider.GetAuthenticationStateAsync();

        if (auth.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/login?returnUrl=profile", forceLoad: false);
            return;
        }

        var idStr = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (int.TryParse(idStr, out var userId))
        {
            _user = await Db.Users.FindAsync(userId);
            if (_user is not null)
            {
                _firstName    = _user.FirstName;
                _lastName     = _user.LastName;
                _selectedPlan = _user.SelectedPlan;
                _annual       = _user.BillingCycle == BillingCycle.Annual;
            }
        }

        _loading = false;
    }

    // ── Helpers ──────────────────────────────────────────────────────
    private DateTime? GetNextPaymentDate()
    {
        if (_user?.PlanSelectedAt is not { } start || _user.SelectedPlan == PlanSlug.None)
            return null;

        var now  = DateTime.UtcNow;
        var next = _user.BillingCycle == BillingCycle.Annual
            ? start.AddYears(1)
            : start.AddMonths(1);

        // Roll forward until the date is in the future
        while (next < now)
            next = _user.BillingCycle == BillingCycle.Annual
                ? next.AddYears(1)
                : next.AddMonths(1);

        return next;
    }

    // ── Actions ──────────────────────────────────────────────────────
    private void SelectPlan(PlanSlug slug) => _selectedPlan = slug;

    private async Task CancelSubscription()
    {
        if (_user is null) return;
        _cancelling = true;

        try
        {
            _user.SelectedPlan   = PlanSlug.None;
            _user.PlanSelectedAt = null;
            _user.ModifiedAt     = DateTime.UtcNow;
            await Db.SaveChangesAsync();

            _selectedPlan        = PlanSlug.None;
            _showCancelConfirm   = false;
            _cancelSuccess       = true;
        }
        catch
        {
            _showCancelConfirm = false;
        }
        finally
        {
            _cancelling = false;
        }
    }

    private async Task SaveProfile()
    {
        if (_user is null) return;
        _saving      = true;
        _saveSuccess = false;
        _saveError   = null;

        try
        {
            var hadNoPlan      = _user.SelectedPlan == PlanSlug.None;
            var isSelectingNew = _selectedPlan != PlanSlug.None;

            _user.FirstName      = _firstName?.Trim();
            _user.LastName       = _lastName?.Trim();
            _user.SelectedPlan   = _selectedPlan;
            _user.BillingCycle   = _annual ? BillingCycle.Annual : BillingCycle.Monthly;
            _user.PlanSelectedAt = _selectedPlan != PlanSlug.None ? (_user.PlanSelectedAt ?? DateTime.UtcNow) : null;
            _user.ModifiedAt     = DateTime.UtcNow;

            await Db.SaveChangesAsync();
            _saveSuccess   = true;
            _cancelSuccess = false; // clear any cancel message

            // Redirect to onboarding when plan was just set and store is not yet provisioned
            if (hadNoPlan && isSelectingNew && _user.ActivationStatus == ActivationStatus.None)
            {
                Nav.NavigateTo("/onboarding", forceLoad: false);
                return;
            }
        }
        catch (Exception ex)
        {
            _saveError = ex.Message;
        }

        _saving = false;
    }
}

<style>
    .profile-page {
        max-width: 900px;
        margin: 0 auto;
        padding: 3rem 1.5rem 5rem;
    }

    .profile-loading {
        display: flex;
        justify-content: center;
        padding: 4rem;
    }

    /* ── Header ── */
    .profile-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .profile-avatar {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: linear-gradient(135deg, #00BFA5, #1A237E);
        color: #fff;
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }

    .profile-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.4rem; font-weight: 700;
        color: #1A237E; margin: 0 0 2px;
    }

    .profile-email { font-size: 0.875rem; color: #607D8B; margin: 0; }

    /* ── Section ── */
    .profile-section {
        background: #fff;
        border: 1px solid #E5E7EB;
        border-radius: 16px;
        padding: 1.75rem;
        margin-bottom: 1.25rem;
    }

    .section-title {
        font-family: 'Syne', sans-serif;
        font-size: 1rem; font-weight: 700;
        color: #1A237E; margin: 0 0 1.25rem;
    }

    .section-header-row {
        display: flex; align-items: center;
        justify-content: space-between;
        flex-wrap: wrap; gap: 0.75rem;
        margin-bottom: 1.25rem;
    }
    .section-header-row .section-title { margin: 0; }

    /* ── Subscription status badge ── */
    .sub-status {
        display: inline-flex; align-items: center; gap: 6px;
        font-size: 0.78rem; font-weight: 600;
        padding: 4px 12px; border-radius: 20px;
    }
    .sub-status--active {
        background: #D1FAE5; color: #065F46;
    }
    .sub-status-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: #10B981;
        animation: pulse-dot 2s ease-in-out infinite;
    }
    @@keyframes pulse-dot {
        0%,100% { opacity:1; }
        50%      { opacity:.4; }
    }
    .sub-status--none {
        background: #F3F4F6; color: #6B7280;
    }
    .sub-status--pending {
        background: #FEF3C7; color: #92400E;
    }
    .sub-status-dot--amber {
        background: #F59E0B;
    }
    .sub-status--setup {
        background: #EFF6FF; color: #1D4ED8;
        font-size: 0.78rem; font-weight: 600;
        padding: 4px 12px; border-radius: 20px;
    }

    /* ── Activation banners ── */
    .activation-banner {
        display: flex; align-items: center; gap: 10px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem; border-radius: 10px;
        padding: 12px 16px; margin-bottom: 1.25rem;
        border: 1px solid transparent;
    }
    .activation-banner--active {
        background: #D1FAE5; border-color: #A7F3D0; color: #065F46;
    }
    .activation-banner--pending {
        background: #FEF3C7; border-color: #FDE68A; color: #92400E;
    }
    .activation-pending-dot {
        width: 8px; height: 8px; border-radius: 50%;
        background: #F59E0B; flex-shrink: 0;
        animation: pulse-dot 2s ease-in-out infinite;
    }

    /* ── Subscription summary grid ── */
    .sub-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        border: 1px solid #E5E7EB;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1.25rem;
    }

    .sub-item {
        padding: 1rem 1.25rem;
        border-right: 1px solid #E5E7EB;
        display: flex; flex-direction: column; gap: 5px;
    }
    .sub-item:last-child { border-right: none; }

    .sub-item-label {
        font-size: 0.72rem; font-weight: 600;
        color: #9CA3AF;
        text-transform: uppercase; letter-spacing: 0.06em;
    }

    .sub-item-value {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem; font-weight: 700;
        color: #1C1C1E;
    }

    .sub-item-value--accent { color: #00897B; }

    .sub-plan-pill {
        display: inline-block;
        background: #E0F7F4;
        color: #00695C;
        padding: 2px 10px;
        border-radius: 20px;
        font-size: 0.82rem;
        font-family: 'DM Sans', sans-serif;
        font-weight: 700;
        width: fit-content;
    }

    .sub-billed-note { font-size: 0.75rem; color: #9CA3AF; font-family: 'DM Sans', sans-serif; font-weight: 400; }

    /* ── No plan ── */
    .sub-no-plan {
        font-size: 0.9rem; color: #6B7280;
        margin: 0; padding: 0.5rem 0;
    }

    /* ── Cancel button ── */
    .btn-cancel-sub {
        background: none; border: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.82rem; font-weight: 600;
        color: #9CA3AF;
        cursor: pointer; padding: 0;
        text-decoration: underline;
        transition: color 0.15s;
    }
    .btn-cancel-sub:hover { color: #E53935; }

    /* ── Cancel confirmation box ── */
    .sub-cancel-box {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 10px;
        padding: 1rem 1.25rem;
        margin-top: 0.25rem;
    }

    .sub-cancel-question {
        font-size: 0.875rem; color: #374151;
        margin: 0 0 0.75rem; line-height: 1.55;
    }

    .sub-cancel-actions { display: flex; gap: 0.75rem; flex-wrap: wrap; }

    .btn-cancel-confirm {
        padding: 8px 20px;
        background: #E53935; color: #fff;
        border: none; border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem; font-weight: 700;
        cursor: pointer; transition: background 0.15s;
    }
    .btn-cancel-confirm:hover:not(:disabled) { background: #C62828; }
    .btn-cancel-confirm:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-cancel-dismiss {
        padding: 8px 20px;
        background: #fff; color: #374151;
        border: 1px solid #D1D5DB;
        border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem; font-weight: 600;
        cursor: pointer; transition: border-color 0.15s;
    }
    .btn-cancel-dismiss:hover { border-color: #9CA3AF; }

    /* ── Cancel success ── */
    .sub-payment-cta {
        margin-top: 16px;
    }

    .sub-cancel-success {
        display: flex; align-items: center; gap: 7px;
        font-size: 0.875rem; font-weight: 600;
        color: #065F46;
        background: #D1FAE5; border: 1px solid #A7F3D0;
        border-radius: 8px; padding: 10px 14px;
        margin-top: 0.25rem;
    }

    /* ── Fields ── */
    .fields-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    }
    .field-group { display: flex; flex-direction: column; gap: 6px; }

    .field-label {
        font-size: 0.78rem; font-weight: 600;
        color: #607D8B;
        text-transform: uppercase; letter-spacing: 0.06em;
    }

    .field-input {
        padding: 10px 14px;
        border: 1px solid #E5E7EB; border-radius: 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9rem; color: #1C1C1E;
        background: #F9FAFB; outline: none;
        transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field-input:focus {
        border-color: #00BFA5;
        box-shadow: 0 0 0 3px rgba(0,191,165,0.12);
        background: #fff;
    }
