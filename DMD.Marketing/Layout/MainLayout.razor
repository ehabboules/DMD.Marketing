@inherits LayoutComponentBase
@using DMD.Marketing.Layout

<MudRTLProvider RightToLeft="false">
    <MudThemeProvider Theme="@_theme" />
    <MudDialogProvider />
    <MudSnackbarProvider />
    <MudPopoverProvider />

    <MudLayout>

        <MobileNav @rendermode="new InteractiveServerRenderMode()" />

        <!-- ═══════════════════════════════════════════════════════════
             MAIN CONTENT
        ════════════════════════════════════════════════════════════════ -->
        <MudMainContent Class="dmd-main-content">

            <!-- Desktop NavBar — hidden on mobile via CSS -->
            <div class="dmd-desktop-navbar">
                <NavBar @rendermode="new InteractiveServerRenderMode()" />
            </div>

            <main>
                @Body
            </main>

            <Footer />

        </MudMainContent>

    </MudLayout>
</MudRTLProvider>

<!-- ─── SCROLL TO TOP ─── -->
<MudScrollToTop>
    <MudFab Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.KeyboardArrowUp"
            Size="Size.Medium"
            Style="box-shadow:0 4px 24px rgba(0,191,165,0.45);" />
</MudScrollToTop>

<style>
    /* ── Responsive: mobile AppBar visible below 960px only ─────── */
    .dmd-mobile-appbar { display: flex !important; }

    /* ── Responsive: desktop NavBar hidden on mobile ────────────── */
    .dmd-desktop-navbar { display: none; }

    @@media (min-width: 960px) {
        .dmd-mobile-appbar  { display: none !important; }
        .dmd-desktop-navbar { display: block; }
        .dmd-main-content   { padding-top: 0 !important; }
    }
</style>

