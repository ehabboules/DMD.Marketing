@inherits LayoutComponentBase

<MudThemeProvider Theme="@_theme" />

<div class="al-bg">
    <div class="al-shell">

        <div class="al-card">
            <div class="al-card-header">
                <a href="/" class="al-header-link">
                    <img src="/images/DMD_POS_scalable.svg" class="al-logo" alt="DMD POS" />
                    <p class="al-brand-name">DMD Inventory</p>
                </a>
            </div>
            <div class="al-card-body">
                @Body
            </div>
        </div>

        <p class="al-footer">© @DateTime.Now.Year DMD Tech · All rights reserved</p>

    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;600;700&display=swap');

    html, body {
        background: #764ba2 !important;
        margin: 0;
        padding: 0;
    }

    .al-bg {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .al-shell {
        width: 100%;
        max-width: 480px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    /* ── Card ── */
    .al-card {
        width: 100%;
        background: #ffffff;
        border-radius: 16px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        overflow: hidden;
        animation: slideIn 0.5s ease-out;
    }

    @@keyframes slideIn {
        from { opacity: 0; transform: translateY(-20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Card Header (purple) ── */
    .al-card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
        text-align: center;
        color: white;
    }

    .al-header-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .al-logo {
        width: 60px;
        height: 60px;
        margin: 0 auto 1rem;
        display: block;
        transition: opacity 0.15s;
    }

    .al-header-link:hover .al-logo { opacity: 0.85; }

    .al-brand-name {
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.9);
        margin: 0;
        font-weight: 400;
    }

    /* ── Card Body ── */
    .al-card-body {
        padding: 2.5rem 2rem;
    }

    /* ── Alerts ── */
    .al-alert-error {
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 9px;
        padding: 10px 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        color: #B91C1C;
        margin-bottom: 1.25rem;
        line-height: 1.5;
    }

    .al-alert-success {
        background: #F0FDF4;
        border: 1px solid #BBF7D0;
        border-radius: 9px;
        padding: 10px 14px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.85rem;
        color: #15803D;
        margin-bottom: 1.25rem;
        line-height: 1.5;
    }

    /* ── Buttons ── */
    .al-btn-primary {
        display: block;
        width: 100%;
        padding: 13px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        border-radius: 9px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.9375rem;
        font-weight: 700;
        color: #fff;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.15s, box-shadow 0.15s;
        margin-top: 0.75rem;
    }

    .al-btn-primary:hover {
        opacity: 0.9;
        box-shadow: 0 4px 18px rgba(102, 126, 234, 0.5);
    }

    .al-btn-primary:disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .al-btn-outline {
        display: block;
        width: 100%;
        padding: 12px;
        background: transparent;
        border: 1.5px solid #E5E7EB;
        border-radius: 9px;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        color: #667eea;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: border-color 0.15s, background 0.15s;
        margin-top: 0.5rem;
    }

    .al-btn-outline:hover {
        border-color: #667eea;
        background: rgba(102, 126, 234, 0.05);
    }

    /* ── Utility ── */
    .al-forgot-row {
        display: flex;
        justify-content: flex-end;
        margin: -0.25rem 0 0.9rem;
    }

    .al-link-sm {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.8rem;
        color: #667eea;
        text-decoration: none;
        transition: color 0.15s;
    }

    .al-link-sm:hover { color: #764ba2; }

    .al-links {
        text-align: center;
        margin-top: 1.5rem;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.875rem;
        color: #90A4AE;
    }

    .al-links a {
        color: #667eea;
        font-weight: 600;
        text-decoration: none;
    }

    .al-links a:hover { text-decoration: underline; }

    .al-footer {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.6);
        text-align: center;
        margin: 0;
    }

    /* ── MudBlazor TextField override ── */
    .mud-input-root {
        font-family: 'DM Sans', sans-serif !important;
        font-size: 0.9375rem !important;
    }

    /* Round the outlined border */
    .mud-input-outlined .mud-notched-outline,
    .mud-input-outlined fieldset {
        border-radius: 9px !important;
    }

    /* Fix floating label — give it a white background so it visually cuts through the border */
    .mud-input-label-outlined.mud-shrink {
        background-color: #ffffff !important;
        padding: 0 4px !important;
    }

    /* 1. Ensure the notched outline has enough space for the label */
    .mud-input-outlined .mud-notched-outline {
        border-radius: 9px !important;
    }

    /* 2. Style the label when it shrinks (floats) */
    .mud-input-label-outlined.mud-shrink {
        background-color: #ffffff !important;
        padding: 0 8px !important;
        margin-top: 2px !important;
        transform: translate(14px, -6px) scale(0.75) !important;
        z-index: 1;
    }

    /* 3. Specifically target the 'legend' element which MudBlazor uses for the notch gap */
    .mud-input-outlined .mud-notched-outline legend {
        width: auto !important;
        padding: 0 !important;
        margin-left: 10px !important;
    }

    @@media (max-width: 480px) {
        .al-shell { max-width: 100%; }
        .al-card-body { padding: 2rem 1.25rem; }
    }
</style>


@code {
    // ── theme ──
    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1976d2",
            Secondary = "#00c853",
            Background = "#f5f5f5",
            AppbarBackground = "#1565c0",
            DrawerBackground = "#ffffff",
            DrawerText = "rgba(0,0,0,0.87)",
            Success = "#00c853",
            Info = "#2196f3",
            Warning = "#ff9800",
            Error = "#f44336",
            Tertiary = "#9c27b0"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#90caf9",
            Secondary = "#69f0ae",
            Background = "#1a1a1a",
            AppbarBackground = "#1e1e1e",
            DrawerBackground = "#2d2d2d",
            DrawerText = "rgba(255,255,255,0.87)",
            Surface = "#2d2d2d"
        },
        Typography = new Typography()
        {
         
                Default = new DefaultTypography()
            {
                FontFamily = new[] { "Roboto", "Helvetica", "Arial", "sans-serif" }
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DrawerWidthLeft = "280px",
            DrawerWidthRight = "300px"
        }
    };
}
