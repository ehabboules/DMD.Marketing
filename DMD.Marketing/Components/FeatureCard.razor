@namespace DMD.Marketing.Components

<div class="fc-card @(Highlighted ? "fc-card--highlighted" : "")">
    <div class="fc-icon-wrap fc-icon-wrap--@ColorKey">
        <span class="fc-icon">@Icon</span>
    </div>
    <h3 class="fc-title">@Title</h3>
    <p class="fc-desc">@Description</p>
    @if (!string.IsNullOrEmpty(Href))
    {
        <a href="@Href" class="fc-link">
            Learn more
            <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Style="font-size:14px;" />
        </a>
    }
</div>

<style>
    .fc-card {
        background: #ffffff;
        border: 1px solid rgba(26,35,126,0.08);
        border-radius: 18px;
        padding: 28px 24px;
        height: 100%;
        display: flex;
        flex-direction: column;
        gap: 12px;
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
        position: relative;
        overflow: hidden;
    }

    .fc-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--dmd-teal), var(--dmd-teal-light, #4DD0C4));
        opacity: 0;
        transition: opacity 0.22s ease;
        border-radius: 18px 18px 0 0;
    }

    .fc-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 48px rgba(26,35,126,0.10);
        border-color: rgba(0,191,165,0.25);
    }

    .fc-card:hover::before {
        opacity: 1;
    }

    .fc-card--highlighted {
        background: linear-gradient(145deg, #f0fdfa 0%, #e8eaf6 100%);
        border-color: rgba(0,191,165,0.30);
    }

    .fc-card--highlighted::before {
        opacity: 1;
    }

    /* ── Icon wrap ── */
    .fc-icon-wrap {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .fc-icon-wrap--teal   { background: rgba(0,191,165,0.12); }
    .fc-icon-wrap--navy   { background: rgba(26,35,126,0.08); }
    .fc-icon-wrap--orange { background: rgba(255,111,0,0.10); }
    .fc-icon-wrap--green  { background: rgba(0,200,83,0.10);  }
    .fc-icon-wrap--red    { background: rgba(229,57,53,0.09);  }
    .fc-icon-wrap--blue   { background: rgba(2,136,209,0.10);  }

    .fc-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.05rem;
        font-weight: 700;
        color: #1A237E;
        margin: 0;
        line-height: 1.3;
    }

    .fc-desc {
        font-size: 0.875rem;
        color: #607D8B;
        line-height: 1.7;
        margin: 0;
        flex: 1;
    }

    .fc-link {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 0.825rem;
        font-weight: 600;
        color: #00BFA5;
        text-decoration: none;
        margin-top: auto;
        transition: gap 0.18s ease;
    }

    .fc-link:hover {
        gap: 9px;
        text-decoration: none;
        color: #00897B;
    }
</style>

@code {
    [Parameter] public string Icon        { get; set; } = "📦";
    [Parameter] public string Title       { get; set; } = "Feature";
    [Parameter] public string Description { get; set; } = "";
    [Parameter] public string Href        { get; set; } = "";
    [Parameter] public bool   Highlighted { get; set; } = false;

    /// <summary>teal | navy | orange | green | red | blue</summary>
    [Parameter] public string ColorKey    { get; set; } = "teal";
}
