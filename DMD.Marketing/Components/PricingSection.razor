@namespace DMD.Marketing.Components

<MudGrid Spacing="3" Justify="Justify.Center">
    @foreach (var plan in _plans)
    {
        <MudItem xs="12" sm="6" md="4">
            <div class="pricing-card @(plan.Featured ? "featured" : "")">
                @if (plan.Featured)
                {
                    <div class="pricing-badge">⭐ Most Popular</div>
                }
                <div class="pricing-plan-name">@plan.Name</div>
                <p style="font-size:0.88rem;color:var(--dmd-text-muted);margin:0 0 0.5rem;">@plan.Tagline</p>
                <div class="pricing-price"><sup>$</sup>@plan.Price</div>
                <div class="pricing-price-period">per month, billed monthly</div>

                <ul class="pricing-feature-list">
                    @foreach (var f in (ShowAllFeatures ? plan.AllFeatures : plan.KeyFeatures))
                    {
                        <li>
                            <span class="@(f.Included ? "check-icon" : "cross-icon")">
                                @(f.Included ? "✓" : "✗")
                            </span>
                            @f.Text
                        </li>
                    }
                </ul>

                <a href="/contact"
                   style="display:block;text-align:center;padding:0.8rem;border-radius:10px;font-weight:700;font-size:0.95rem;text-decoration:none;transition:all 0.2s;
                          @(plan.Featured
                              ? "background:var(--dmd-teal);color:var(--dmd-navy);"
                              : "background:var(--dmd-navy);color:#fff;")">
                    Get Started →
                </a>
            </div>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] public bool ShowAllFeatures { get; set; } = true;

    private record PlanFeature(string Text, bool Included = true);
    private record PricingPlan(string Name, string Tagline, int Price, bool Featured,
        List<PlanFeature> KeyFeatures, List<PlanFeature> AllFeatures);

    private List<PricingPlan> _plans = new()
